  var gateForm   = document.getElementById('pcs-gate-form');
  var btnRec     = document.getElementById('pcs-gate-btn-recruiter');
  var btnKnow    = document.getElementById('pcs-gate-btn-knowledge');
  var btnSubmit  = document.getElementById('pcs-gate-submit');
  var sendStatus = document.getElementById('pcs-gate-send-status');
  var ctaSwitch  = document.getElementById('pcs-cta-switch-knowledge');

  /* ── Validation ──────────────────────────────────────── */
  var BLOCKED = ['test.com','example.com','fake.com','mailinator.com',
    'guerrillamail.com','throwaway.email','temp-mail.org','yopmail.com',
    'sharklasers.com','spam4.me','noemail.com','nomail.com'];

  function isValidEmail(e) {
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(e)) return false;
    return !BLOCKED.includes(e.split('@')[1].toLowerCase());
  }

  function setErr(inputId, errId, msg) {
    var err = document.getElementById(errId);
    var inp = document.getElementById(inputId);
    if (err) err.textContent = msg;
    if (inp) msg ? inp.classList.add('error') : inp.classList.remove('error');
  }

  function clearErrors() {
    setErr('pcs-form-name',    'pcs-err-name',    '');
    setErr('pcs-form-company', 'pcs-err-company', '');
    setErr('pcs-form-email',   'pcs-err-email',   '');
  }

  function validateForm() {
    var name    = document.getElementById('pcs-form-name').value.trim();
    var company = document.getElementById('pcs-form-company').value.trim();
    var email   = document.getElementById('pcs-form-email').value.trim();
    clearErrors();
    var ok = true;
    if (!name)              { setErr('pcs-form-name',    'pcs-err-name',    'Full name is required');              ok = false; }
    if (!company)           { setErr('pcs-form-company', 'pcs-err-company', 'Company / organisation is required'); ok = false; }
    if (!email)             { setErr('pcs-form-email',   'pcs-err-email',   'Work email is required');             ok = false; }
    else if (!isValidEmail(email)) { setErr('pcs-form-email', 'pcs-err-email', 'Please enter a valid work email'); ok = false; }
    return ok;
  }

  function getFormData() {
    return {
      name:     document.getElementById('pcs-form-name').value.trim(),
      company:  document.getElementById('pcs-form-company').value.trim(),
      email:    document.getElementById('pcs-form-email').value.trim(),
      linkedin: (document.getElementById('pcs-form-linkedin').value || '').trim() || 'Not provided',
    };
  }

  /* ── EmailJS ─────────────────────────────────────────── */
  function ejsParams(data, recipientEmail) {
    return {
      recruiter_name:     data.name,
      recruiter_company:  data.company,
      recruiter_linkedin: data.linkedin,
      recruiter_email:    recipientEmail,
      timestamp: new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }),
    };
  }

  // On gate unlock: Welcome → recruiter, Contact-US → owner as notification
  function sendAccessEmails(data, done) {
    if (!window.emailjs) { done(null); return; }
    Promise.all([
      emailjs.send(PCS_EJS_SERVICE, PCS_EJS_WELCOME, ejsParams(data, data.email)),
      emailjs.send(PCS_EJS_SERVICE, PCS_EJS_RESUME,  ejsParams(data, PCS_OWNER)),
    ]).then(function() { done(null); }).catch(function(e) { done(e); });
  }

  // On resume request: Contact-US → recruiter, Welcome → owner as notification
  function sendResumeEmails(data, done) {
    if (!window.emailjs) { done(null); return; }
    Promise.all([
      emailjs.send(PCS_EJS_SERVICE, PCS_EJS_RESUME,  ejsParams(data, data.email)),
      emailjs.send(PCS_EJS_SERVICE, PCS_EJS_WELCOME, ejsParams(data, PCS_OWNER)),
    ]).then(function() { done(null); }).catch(function(e) { done(e); });
  }

  /* ── Mode switch ─────────────────────────────────────── */
  function applyMode(mode, skipSave) {
    if (!skipSave) { try { localStorage.setItem('pcs-visitor', mode); } catch(e) {} }
    if (mode === 'recruiter') {
      recView.style.display  = 'block';
      knowView.style.display = 'none';
      modeInd.textContent    = 'Recruiter view';
      modeSwitch.textContent = 'Switch to technical view →';
    } else {
      recView.style.display  = 'none';
      knowView.style.display = 'block';
      modeInd.textContent    = 'Technical view';
      modeSwitch.textContent = 'Switch to recruiter view →';
    }
    gate.style.display           = 'none';
    modeBar.style.display        = 'block';
    document.body.style.overflow = '';
  }

  /* ── Init ────────────────────────────────────────────── */
  var stored = null;
  try { stored = localStorage.getItem('pcs-visitor'); } catch(e) {}
  if (stored === 'recruiter' || stored === 'knowledge') {
    applyMode(stored, true);
  } else {
    gate.style.display           = 'flex';
    document.body.style.overflow = 'hidden';
  }

  /* ── Gate card handlers ──────────────────────────────── */
  if (btnKnow) btnKnow.addEventListener('click', function() { applyMode('knowledge'); });

  if (btnRec) {
    btnRec.addEventListener('click', function() {
      gateForm.classList.add('visible');
      btnRec.style.borderColor = 'rgba(196,97,74,0.5)';
      if (btnKnow) btnKnow.style.opacity = '0.4';
    });
  }

  /* ── Form submit ─────────────────────────────────────── */
  if (btnSubmit) {
    btnSubmit.addEventListener('click', function() {
      if (!validateForm()) return;
      var data = getFormData();
      try { localStorage.setItem('pcs-recruiter-data', JSON.stringify(data)); } catch(e) {}

      btnSubmit.disabled    = true;
      btnSubmit.textContent = 'Sending…';
      if (sendStatus) { sendStatus.textContent = 'Verifying details…'; sendStatus.className = 'pcs-gate-send-status sending'; }

      sendAccessEmails(data, function(err) {
        if (err) console.warn('EmailJS access error:', err);
        applyMode('recruiter');
      });
    });
  }

  /* ── Mode bar + CTA switch ───────────────────────────── */
  if (modeSwitch) {
    modeSwitch.addEventListener('click', function() {
      var cur = null; try { cur = localStorage.getItem('pcs-visitor'); } catch(e) {}
      applyMode(cur === 'recruiter' ? 'knowledge' : 'recruiter');
    });
  }
  if (ctaSwitch) ctaSwitch.addEventListener('click', function() { applyMode('knowledge'); });

  /* ── Resume request ──────────────────────────────────── */
  var resumeBtn    = document.getElementById('pcs-resume-btn');
  var resumeStatus = document.getElementById('pcs-resume-status');

  if (resumeBtn) {
    resumeBtn.addEventListener('click', function() {
      var data = null;
      try { data = JSON.parse(localStorage.getItem('pcs-recruiter-data')); } catch(e) {}
      if (!data) return;

      resumeBtn.disabled    = true;
      resumeBtn.textContent = 'Sending request…';

      sendResumeEmails(data, function(err) {
        if (err) console.warn('EmailJS resume error:', err);
        resumeBtn.textContent = 'Requested ✓';
        if (resumeStatus) {
          resumeStatus.textContent =
            'Hi ' + data.name + ', your request has been received. ' +
            'Sudheesh will send his resume to ' + data.email + ' within 24 hours.';
          resumeStatus.style.display = 'block';
        }
      });
    });
  }
})();

/* ── Tab switching ─────────────────────────────────────── */
document.querySelectorAll('.pcs-tab').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var tab = btn.dataset.tab;
    document.querySelectorAll('.pcs-tab').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.pcs-panel').forEach(function(p) { p.classList.remove('active'); });
    btn.classList.add('active');
    var panel = document.getElementById('panel-' + tab);
    if (panel) panel.classList.add('active');
    if (window.innerWidth < 860) window.scrollTo({ top: document.querySelector('.pcs-tab-nav').offsetTop, behavior: 'smooth' });
  });
});

/* ── Component accordion ───────────────────────────────── */
function pcsToggle(id) {
  var item = document.getElementById('comp-' + id);
  if (!item) return;
  var isOpen = item.classList.contains('pcs-comp-item--open');
  document.querySelectorAll('.pcs-comp-item--open').forEach(function(el) {
    el.classList.remove('pcs-comp-item--open');
    var btn = el.querySelector('.pcs-comp-row');
    if (btn) btn.setAttribute('aria-expanded', 'false');
  });
  if (!isOpen) {
    item.classList.add('pcs-comp-item--open');
    var btn = item.querySelector('.pcs-comp-row');
    if (btn) btn.setAttribute('aria-expanded', 'true');
  }
}

/* ── Component detail tabs ─────────────────────────────── */
function pcsDetTab(btn, compId, pane) {
  var det = btn.closest('.pcs-comp-det');
  if (!det) return;
  det.querySelectorAll('.pcs-det-tab').forEach(function(t) { t.classList.remove('active'); });
  det.querySelectorAll('.pcs-det-pane').forEach(function(p) { p.classList.remove('active'); });
  btn.classList.add('active');
  var target = det.querySelector('[data-comp="' + compId + '"][data-pane="' + pane + '"]');
  if (target) target.classList.add('active');
}

/* ── Intersection observer: fade-in ───────────────────── */
(function() {
  if (!window.IntersectionObserver) return;
  var cards = document.querySelectorAll('.pcs-enh-card, .pcs-related-card, .pcs-rec-hl, .pcs-rec-bullet');
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.04 });
  cards.forEach(function(el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(14px)';
    el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
    io.observe(el);
  });
})();
</script>

</BaseLayout>
