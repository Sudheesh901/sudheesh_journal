---
import { getCollection } from 'astro:content';
import ArticleLayout from '@/layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('experience');
  const excluded = ['ai-engineer-production-systems', 'data-scientist-recommendation-nlp'];
  return entries
    .filter((entry) => !excluded.includes(entry.slug))
    .map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
---

<ArticleLayout entry={entry} active="experience" />
