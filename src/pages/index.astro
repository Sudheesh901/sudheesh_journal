---
import BaseLayout from '@/layouts/BaseLayout.astro';

const facts = [
  { val: '4 yrs',  lbl: 'AI/ML in production' },
  { val: '500K+',  lbl: 'Users in RecSys'      },
  { val: '12',     lbl: 'Roadmap stages'        },
  { val: 'Open',   lbl: 'All knowledge public'  },
];

const knowledge = [
  {
    eye: 'AI Engineering', count: '12 stages',
    title: 'AI Engineer Roadmap',
    desc: 'FastAPI → RAG → Agents → Inference → Safety → Ship. Every stage has production code, pitfalls, and interview Q&A.',
    href: '/ai-engineering/ai-engineer-roadmap',
  },
  {
    eye: 'LLMs & NLP', count: '8 stages',
    title: 'Language Systems',
    desc: 'Transformers, prompting, retrieval, agents, cost control, and reliability — with trade-offs at every layer.',
    href: '/ai-engineering/llms-nlp',
  },
  {
    eye: 'Foundations', count: '3 tracks',
    title: 'ML Foundations',
    desc: 'AI/ML theory, statistics, and deep learning as durable mental models — before tools, not after.',
    href: '/foundations',
  },
  {
    eye: 'Interview Prep', count: '3 guides',
    title: 'Interview Preparation',
    desc: 'System design frameworks, LLM evaluation rubrics, and STAR stories grounded in real production work.',
    href: '/interview',
  },
];

const work = [
  {
    role: 'AI Engineer',
    title: 'LLM Systems & Production AI',
    desc: 'Built and deployed LLM-powered search, RAG pipelines, and real-time inference systems. FastAPI, LangGraph, vLLM, Qdrant.',
    tags: ['LLMs', 'RAG', 'FastAPI', 'vLLM'],
    href: '/experience/ai-engineer-production-systems',
  },
  {
    role: 'Data Scientist',
    title: 'Recommendation Systems & NLP',
    desc: 'Collaborative filtering, NLP classification, and A/B experimentation pipelines serving 500K+ user events in production.',
    tags: ['RecSys', 'NLP', 'MLOps', 'A/B'],
    href: '/experience/data-scientist-recommendation-nlp',
  },
];
---

<BaseLayout active="home">
  <main class="hp-root">

    <!-- ══ HERO ══════════════════════════════════════════════════ -->
    <section class="hp-hero">

      <!-- Gradient orbs — Claude-style ambient colour -->
      <div class="hp-orb hp-orb-1" aria-hidden="true"></div>
      <div class="hp-orb hp-orb-2" aria-hidden="true"></div>
      <div class="hp-orb hp-orb-3" aria-hidden="true"></div>

      <div class="hp-hero-inner">

        <!-- Wordmark — wipe reveal like Anthropic logo -->
        <div class="hp-wordmark-wrap">
          <span class="hp-wordmark">SUDHEESH K. REDDY</span>
          <span class="hp-wordmark-sub">AI Engineer &nbsp;·&nbsp; Hyderabad</span>
        </div>

        <h1 class="hp-h1">
          The AI engineering<br>
          knowledge base<br>
          <em>you wished existed.</em>
        </h1>

        <p class="hp-sub">
          Four years of production LLMs, RAG pipelines, and ML systems —
          documented with code, trade-offs, and the failures you won't find in tutorials.
        </p>

        <div class="hp-ctas">
          <a href="/ai-engineering" class="hp-btn-primary">
            Browse Knowledge Base
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7h9m0 0L8 3.5M11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/experience" class="hp-btn-ghost">View Experience</a>
        </div>

        <div class="hp-avail">
          <span class="hp-pulse" aria-hidden="true"></span>
          Open to new opportunities
        </div>

      </div>
    </section>

    <!-- ══ FACTS BAR ══════════════════════════════════════════════ -->
    <div class="hp-facts" role="list">
      {facts.map(f => (
        <div class="hp-fact" role="listitem">
          <span class="hp-fact-val">{f.val}</span>
          <span class="hp-fact-lbl">{f.lbl}</span>
        </div>
      ))}
    </div>

    <!-- ══ KNOWLEDGE BASE ════════════════════════════════════════ -->
    <section class="hp-kb">
      <div class="hp-kb-inner">

        <div class="hp-kb-left">
          <p class="hp-eye">Knowledge Base</p>
          <h2 class="hp-h2">
            Production depth.<br>
            <em>Not another tutorial.</em>
          </h2>
          <p class="hp-kb-prose">
            Every section is built around real production challenges —
            not what the docs say, but what breaks at 3am and why.
            Code that runs, pitfalls that cost weeks.
          </p>
          <a href="/ai-engineering" class="hp-link">
            Explore all sections
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M2 6.5h9m0 0L7.5 3M11 6.5L7.5 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="hp-kb-grid">
          {knowledge.map(k => (
            <a href={k.href} class="hp-kb-card">
              <div class="hp-kb-card-top">
                <span class="hp-kb-eye">{k.eye}</span>
                <span class="hp-kb-count">{k.count}</span>
              </div>
              <div class="hp-kb-card-title">{k.title}</div>
              <p class="hp-kb-card-desc">{k.desc}</p>
              <div class="hp-kb-card-arrow" aria-hidden="true">→</div>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- ══ SELECTED WORK ══════════════════════════════════════════ -->
    <section class="hp-work">
      <div class="hp-work-inner">

        <div class="hp-work-head">
          <div>
            <p class="hp-eye">Selected Work</p>
            <h2 class="hp-h2 hp-h2--sm">Where it was <em>built.</em></h2>
          </div>
          <a href="/experience" class="hp-link hp-link--right">
            All experience
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M2 6.5h9m0 0L7.5 3M11 6.5L7.5 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="hp-work-list">
          {work.map(w => (
            <a href={w.href} class="hp-work-item">
              <div class="hp-work-body">
                <div class="hp-work-role">{w.role}</div>
                <h3 class="hp-work-title">{w.title}</h3>
                <p class="hp-work-desc">{w.desc}</p>
              </div>
              <div class="hp-work-meta">
                <div class="hp-work-tags">
                  {w.tags.map(t => <span class="hp-tag">{t}</span>)}
                </div>
                <span class="hp-work-arrow" aria-hidden="true">→</span>
              </div>
            </a>
          ))}
        </div>

      </div>
    </section>

  </main>
</BaseLayout>

<style is:global>
/* ════════════════════════════════════════
   HOME PAGE  —  hp-* namespace
   Dark hero + linen content sections
════════════════════════════════════════ */

.hp-root {
  display: block;
  min-height: 100vh;
  padding-top: var(--nav-h);
}

/* ════════════════════════════════════════
   HERO — dark, gradient orbs
════════════════════════════════════════ */
.hp-hero {
  position: relative;
  background: #0C0B09;
  overflow: hidden;
  min-height: calc(100vh - var(--nav-h));
  display: flex;
  align-items: center;
  padding: clamp(52px, 8vh, 96px) var(--page-pad);
}

/* ── Gradient orbs ── */
.hp-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  will-change: transform;
}
.hp-orb-1 {
  width: 820px;
  height: 820px;
  top: -280px;
  right: -160px;
  background: radial-gradient(circle at center,
    rgba(196, 97, 74, 0.38) 0%,
    rgba(217, 115, 85, 0.15) 40%,
    transparent 70%
  );
  filter: blur(56px);
  animation: hp-orb1 15s ease-in-out infinite;
}
.hp-orb-2 {
  width: 640px;
  height: 640px;
  bottom: -220px;
  left: -140px;
  background: radial-gradient(circle at center,
    rgba(70, 80, 175, 0.28) 0%,
    rgba(90, 100, 190, 0.1) 40%,
    transparent 70%
  );
  filter: blur(70px);
  animation: hp-orb2 18s ease-in-out infinite;
}
.hp-orb-3 {
  width: 480px;
  height: 480px;
  top: 40%;
  left: 50%;
  background: radial-gradient(circle at center,
    rgba(184, 122, 40, 0.12) 0%,
    transparent 65%
  );
  filter: blur(80px);
  animation: hp-orb3 12s ease-in-out infinite 1.5s;
}

@keyframes hp-orb1 {
  0%, 100% { transform: translate(0, 0); }
  33%       { transform: translate(-55px, 45px); }
  66%       { transform: translate(35px, -30px); }
}
@keyframes hp-orb2 {
  0%, 100% { transform: translate(0, 0); }
  33%       { transform: translate(45px, -50px); }
  66%       { transform: translate(-30px, 35px); }
}
@keyframes hp-orb3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50%       { transform: translate(-50px, 25px) scale(1.2); }
}

/* ── Hero inner ── */
.hp-hero-inner {
  position: relative;
  z-index: 2;
  max-width: 800px;
}

/* ── Wordmark — Anthropic-style clip-path wipe reveal ── */
.hp-wordmark-wrap {
  margin-bottom: clamp(44px, 6vh, 72px);
}
.hp-wordmark {
  display: block;
  font-family: var(--sans);
  font-size: clamp(1.25rem, 1.9vw, 1.6rem);
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #F5F3EF;
  clip-path: inset(0 100% 0 0);
  animation: hp-wipe 1.0s cubic-bezier(0.4, 0, 0.2, 1) forwards 0.1s;
}
.hp-wordmark-sub {
  display: block;
  font-family: var(--mono);
  font-size: 0.59rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(245, 243, 239, 0.28);
  margin-top: 7px;
  animation: hp-fadein 0.6s ease both 0.95s;
}

@keyframes hp-wipe {
  from { clip-path: inset(0 100% 0 0); }
  to   { clip-path: inset(0 0% 0 0);   }
}
@keyframes hp-fadein {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0);    }
}

/* ── Headline ── */
.hp-h1 {
  font-family: var(--sans);
  font-weight: 900;
  font-size: clamp(2.8rem, 6.2vw, 5.5rem);
  line-height: 0.92;
  letter-spacing: -0.04em;
  color: #F5F3EF;
  margin-bottom: 26px;
  animation: hp-fadein 0.7s ease both 0.55s;
}
.hp-h1 em {
  font-family: var(--display);
  font-style: italic;
  font-weight: 400;
  letter-spacing: -0.03em;
  color: #D97355; /* --terra2 */
}

/* ── Sub ── */
.hp-sub {
  font-size: clamp(0.93rem, 1.5vw, 1.08rem);
  color: rgba(245, 243, 239, 0.5);
  font-family: var(--sans);
  line-height: 1.78;
  max-width: 500px;
  margin-bottom: 36px;
  animation: hp-fadein 0.7s ease both 0.72s;
}

/* ── CTAs ── */
.hp-ctas {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 44px;
  animation: hp-fadein 0.7s ease both 0.88s;
}

/* Primary: warm white on dark */
.hp-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 22px;
  background: #F5F3EF;
  color: #0C0B09;
  font-family: var(--sans);
  font-size: 0.85rem;
  font-weight: 700;
  text-decoration: none;
  border-radius: 7px;
  letter-spacing: -0.01em;
  transition: background 0.18s, transform 0.18s, box-shadow 0.18s;
}
.hp-btn-primary:hover {
  background: #FFFFFF;
  transform: translateY(-1px);
  box-shadow: 0 6px 24px rgba(245, 243, 239, 0.18);
}

/* Ghost: translucent border on dark */
.hp-btn-ghost {
  display: inline-flex;
  align-items: center;
  padding: 12px 22px;
  background: transparent;
  color: rgba(245, 243, 239, 0.65);
  font-family: var(--sans);
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  border-radius: 7px;
  border: 1px solid rgba(245, 243, 239, 0.18);
  letter-spacing: -0.01em;
  transition: border-color 0.18s, color 0.18s, background 0.18s;
}
.hp-btn-ghost:hover {
  border-color: rgba(245, 243, 239, 0.4);
  color: #F5F3EF;
  background: rgba(245, 243, 239, 0.06);
}

/* ── Availability pill ── */
.hp-avail {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--mono);
  font-size: 0.61rem;
  font-weight: 500;
  color: rgba(100, 160, 108, 0.9);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  animation: hp-fadein 0.7s ease both 1.05s;
}
.hp-pulse {
  display: block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #4A6B50;
  flex-shrink: 0;
  animation: hp-pulse-anim 2.4s ease infinite;
}
@keyframes hp-pulse-anim {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(74, 107, 80, 0.6); }
  60%       { opacity: 0.8; box-shadow: 0 0 0 6px rgba(74, 107, 80, 0); }
}

/* ════════════════════════════════════════
   FACTS BAR
════════════════════════════════════════ */
.hp-facts {
  display: flex;
  background: var(--linen2);
  border-bottom: 1px solid var(--linen3);
  overflow-x: auto;
  scrollbar-width: none;
}
.hp-facts::-webkit-scrollbar { display: none; }

.hp-fact {
  flex: 1;
  min-width: 150px;
  padding: 22px var(--page-pad);
  border-right: 1px solid var(--linen3);
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.hp-fact:last-child { border-right: none; }

.hp-fact-val {
  font-family: var(--sans);
  font-size: clamp(1.5rem, 2.2vw, 2rem);
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -0.04em;
  line-height: 1;
}
.hp-fact-lbl {
  font-family: var(--mono);
  font-size: 0.59rem;
  color: var(--muted2);
  text-transform: uppercase;
  letter-spacing: 0.09em;
}

/* ════════════════════════════════════════
   SHARED SECTION TYPOGRAPHY
════════════════════════════════════════ */
.hp-eye {
  font-family: var(--mono);
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--terra);
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 0 0 16px;
}
.hp-eye::before {
  content: '';
  display: block;
  width: 18px;
  height: 1px;
  background: var(--terra);
  flex-shrink: 0;
}

.hp-h2 {
  font-family: var(--sans);
  font-weight: 900;
  font-size: clamp(1.9rem, 3.2vw, 2.6rem);
  line-height: 1.0;
  letter-spacing: -0.035em;
  color: var(--ink);
  margin: 0 0 20px;
}
.hp-h2 em {
  font-family: var(--display);
  font-style: italic;
  font-weight: 400;
  letter-spacing: -0.025em;
  color: var(--ink);
}
.hp-h2--sm { font-size: clamp(1.6rem, 2.4vw, 2.1rem); }

.hp-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--sans);
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 1px solid var(--linen3);
  padding-bottom: 1px;
  transition: border-color 0.18s, gap 0.18s;
}
.hp-link:hover { border-color: var(--ink); gap: 10px; }
.hp-link--right { align-self: flex-start; margin-top: 4px; }

/* ════════════════════════════════════════
   KNOWLEDGE BASE
════════════════════════════════════════ */
.hp-kb {
  padding: clamp(48px, 6vw, 72px) var(--page-pad);
  border-bottom: 1px solid var(--linen3);
}
.hp-kb-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 5fr 7fr;
  gap: clamp(40px, 6vw, 88px);
  align-items: start;
}
.hp-kb-left {
  position: sticky;
  top: calc(var(--nav-h) + 24px);
}
.hp-kb-prose {
  font-size: 0.92rem;
  color: var(--muted);
  line-height: 1.8;
  margin: 0 0 26px;
}

/* 2×2 hairline grid */
.hp-kb-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--linen3);
  border: 1px solid var(--linen3);
  border-radius: 14px;
  overflow: hidden;
}
.hp-kb-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  padding: 22px 20px;
  background: var(--linen);
  transition: background 0.2s;
}
.hp-kb-card:hover { background: var(--linen2); }
.hp-kb-card:hover .hp-kb-card-arrow { opacity: 1; transform: translateX(3px); }

.hp-kb-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.hp-kb-eye {
  font-family: var(--mono);
  font-size: 0.57rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--terra);
}
.hp-kb-count {
  font-family: var(--mono);
  font-size: 0.57rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted2);
}
.hp-kb-card-title {
  font-family: var(--sans);
  font-size: 0.92rem;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.015em;
  line-height: 1.25;
  margin-bottom: 9px;
}
.hp-kb-card-desc {
  font-size: 0.75rem;
  color: var(--muted2);
  line-height: 1.7;
  margin: 0;
  flex: 1;
}
.hp-kb-card-arrow {
  font-family: var(--mono);
  font-size: 0.78rem;
  color: var(--muted2);
  margin-top: 14px;
  opacity: 0;
  transition: opacity 0.18s, transform 0.18s;
  align-self: flex-end;
}

/* ════════════════════════════════════════
   SELECTED WORK
════════════════════════════════════════ */
.hp-work {
  padding: clamp(48px, 6vw, 72px) var(--page-pad)
           clamp(56px, 7vw, 88px);
}
.hp-work-inner {
  max-width: 1200px;
  margin: 0 auto;
}
.hp-work-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 36px;
  gap: 20px;
}

.hp-work-list {
  border: 1px solid var(--linen3);
  border-radius: 14px;
  overflow: hidden;
}
.hp-work-item {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 32px;
  align-items: center;
  padding: 30px 36px;
  background: var(--linen);
  border-bottom: 1px solid var(--linen3);
  text-decoration: none;
  color: inherit;
  transition: background 0.2s;
}
.hp-work-item:last-child { border-bottom: none; }
.hp-work-item:hover { background: var(--linen2); }
.hp-work-item:hover .hp-work-arrow { transform: translateX(5px); color: var(--ink); }

.hp-work-role {
  font-family: var(--mono);
  font-size: 0.59rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted2);
  margin-bottom: 7px;
}
.hp-work-title {
  font-family: var(--sans);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.2;
  margin: 0 0 9px;
}
.hp-work-desc {
  font-size: 0.81rem;
  color: var(--muted);
  line-height: 1.68;
  margin: 0;
  max-width: 540px;
}

.hp-work-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16px;
  flex-shrink: 0;
}
.hp-work-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  justify-content: flex-end;
}
.hp-tag {
  font-family: var(--mono);
  font-size: 0.57rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted2);
  background: var(--linen2);
  border: 1px solid var(--linen3);
  border-radius: 4px;
  padding: 3px 7px;
}
.hp-work-arrow {
  font-family: var(--mono);
  font-size: 0.95rem;
  color: var(--linen3);
  transition: transform 0.2s, color 0.2s;
}

/* ════════════════════════════════════════
   RESPONSIVE
════════════════════════════════════════ */
@media (max-width: 1024px) {
  .hp-kb-inner { grid-template-columns: 1fr; gap: 44px; }
  .hp-kb-left  { position: static; }
}

@media (max-width: 768px) {
  .hp-work-item {
    grid-template-columns: 1fr;
    gap: 18px;
    padding: 24px 22px;
  }
  .hp-work-meta {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
  .hp-work-head { flex-direction: column; align-items: flex-start; }
  .hp-orb-1 { width: 480px; height: 480px; }
  .hp-orb-2 { width: 380px; height: 380px; }
  .hp-orb-3 { display: none; }
}

@media (max-width: 560px) {
  .hp-h1 { font-size: clamp(2.3rem, 10.5vw, 3.2rem); }
  .hp-kb-grid { grid-template-columns: 1fr; }
  .hp-facts { flex-wrap: wrap; }
  .hp-fact { min-width: 50%; }
  .hp-fact:nth-child(2) { border-right: none; }
  .hp-fact:nth-child(3),
