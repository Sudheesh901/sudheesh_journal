---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
---

<BaseLayout title="Collaborate - Sudheesh K. Reddy" active="collaborate">
  <main class="page active">
    <PageHero eyebrow="Collaborate" title="Build practical AI systems together." description="Open to AI engineering roles, advisory work, open-source collaboration, and production-focused experiments around retrieval, evaluation, agents, and MLOps." />
    <section class="section">
      <div class="container">
        <div class="topic-grid">
          <div class="topic-card"><div class="topic-name">AI Engineering Roles</div><p class="topic-desc">End-to-end ownership across LLM systems, RAG, agents, data pipelines, and production reliability.</p></div>
          <div class="topic-card"><div class="topic-name">Technical Advisory</div><p class="topic-desc">Architecture reviews, evaluation design, MLOps strategy, and prototype-to-production planning.</p></div>
          <div class="topic-card"><div class="topic-name">Open Source</div><p class="topic-desc">Especially interested in AI evaluation, retrieval systems, and engineering education resources.</p></div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
