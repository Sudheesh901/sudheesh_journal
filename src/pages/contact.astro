---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
---

<BaseLayout title="Contact - Sudheesh K. Reddy" active="contact">
  <main class="page active">
    <PageHero eyebrow="Contact" title="Start a focused conversation." description="Use this page for roles, collaboration, project discussion, advisory work, or knowledge-base contributions." />
    <section class="section">
      <div class="container-sm">
        <div id="contactFormWrap">
          <form class="contact-form" onsubmit="event.preventDefault(); submitContact()">
            <div class="form-row">
              <input id="cf-name" class="form-input" name="name" placeholder="Name" required />
              <input id="cf-email" class="form-input" name="email" type="email" placeholder="Email" required />
            </div>
            <input id="cf-org" class="form-input" name="organisation" placeholder="Organisation (optional)" />
            <input id="cf-purpose" class="form-input" name="purpose" placeholder="Purpose (role, collaboration, advisory…)" />
            <textarea id="cf-msg" class="form-textarea" name="message" placeholder="Tell me what you want to build, discuss, or explore." required></textarea>
            <div class="hp-field" aria-hidden="true">
              <input id="cf-website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <div id="contactError" class="form-error"></div>
            <button id="contactSubmitBtn" class="btn btn-primary" type="submit">Send Message</button>
          </form>
        </div>
        <div id="contactSuccess" class="success-msg">
          <h4>Message sent.</h4>
          <p>Thanks for reaching out — I'll get back to you shortly.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
