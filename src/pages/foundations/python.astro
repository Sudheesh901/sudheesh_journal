    pipe,
    param_grid={"log__offset": [0.0, 0.5, 1.0, 2.0]},  # step__param syntax
    cv=5,
    scoring="f1",
)
grid.fit(X_train, y_train)
print(grid.best_params_)    # {'log__offset': 1.0}
print(grid.best_score_)     # 0.912

