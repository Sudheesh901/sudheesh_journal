        <div class="rm-hero-left">
          <div class="rm-eyebrow">
            <span class="rm-badge">Foundations</span>
            <span class="rm-badge-sep">·</span>
            <span class="rm-badge-count">12 Stages</span>
          </div>

          <h1 class="rm-hero-title">
            <span class="rm-ht-sans">Python</span>
            <span class="rm-ht-serif">for AI & Data.</span>
          </h1>

          <p class="rm-hero-desc">
            From language core to NumPy, Pandas, async, and performance — every stage built for Data Scientists and AI Engineers, with production pitfalls and interview Q&amp;A throughout.
          </p>

          <div class="rm-hero-tools">
            {['NumPy','Pandas','asyncio','mypy','pytest','functools','itertools','dataclasses'].map(t => (
              <span class="rm-tool-pill">{t}</span>
            ))}
          </div>
        </div>

        <nav class="rm-hero-index" aria-label="Stage index">
          {layers.map(layer => (
            <div class="rm-idx-layer">
              <div class="rm-idx-layer-label" data-layer={layer.id}>
                {layer.label}
                <span class="rm-idx-range">{layer.range}</span>
              </div>
              {layer.stages.map(stage => (
                <a class="rm-idx-item" href={`#stage-${stage.num}`}>
                  <span class="rm-idx-num">{stage.num}</span>
                  <span class="rm-idx-title">{stage.title}</span>
                </a>
              ))}
            </div>
          ))}
        </nav>

      </div>
    </section>

    <!-- ══ BODY ══════════════════════════════════════════════ -->
    <div class="rm-body">

      {layers.map(layer => (
        <section class="rm-layer" data-layer={layer.id}>

          <div class="rm-layer-head">
            <div class="rm-lh-line"></div>
            <div class="rm-lh-label">
              <span class="rm-lh-name">{layer.label}</span>
              <span class="rm-lh-range">{layer.range}</span>
            </div>
            <div class="rm-lh-line"></div>
          </div>

          <div class="rm-track">
            {layer.stages.map(stage => (
              <article class="rm-stage" id={`stage-${stage.num}`}>

                <div class="rm-stage-gutter">
                  <div class="rm-stage-dot"></div>
                  <div class="rm-stage-num">{stage.num}</div>
                </div>

                <div class="rm-stage-content">
                  <h2 class="rm-stage-title">{stage.title}</h2>
                  <p class="rm-stage-intro">{stage.intro}</p>

                  <div class="rm-spec">
                    {stage.points.map((p) => (
                      <div class="rm-spec-item">
                        <div
                          class:list={['rm-spec-row', p.detail && 'rm-spec-row--has-detail']}
                          onclick={p.detail ? 'rmToggle(this)' : undefined}
                        >
                          <div class="rm-spec-term">{p.term}</div>
                          <div class="rm-spec-desc">{p.desc}</div>
                          {p.detail && (
                            <div class="rm-spec-chevron" aria-hidden="true">
                              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </div>
                          )}
                        </div>
                        {p.detail && (
                          <div class="rm-det">
                            <nav class="rm-det-tabs">
                              <button class="rm-det-tab rm-det-tab--active" onclick="rmTab(this,'overview')" type="button">Overview</button>
                              <button class="rm-det-tab" onclick="rmTab(this,'code')" type="button">Code</button>
                              <button class="rm-det-tab" onclick="rmTab(this,'production')" type="button">In Production</button>
                              <button class="rm-det-tab" onclick="rmTab(this,'qa')" type="button">Interview Q&amp;A</button>
                            </nav>
                            <div class="rm-det-body">
                              <div class="rm-det-pane rm-det-pane--active" data-pane="overview">
                                <p class="rm-det-overview">{p.detail.overview}</p>
                              </div>
                              <div class="rm-det-pane" data-pane="code">
                                <div class="rm-code">
                                  <div class="rm-code-bar">
                                    <span class="rm-code-lang">{p.detail.code.label}</span>
                                    <div class="rm-code-dots">
                                      <span class="rm-dot rm-dot--r"></span>
                                      <span class="rm-dot rm-dot--y"></span>
                                      <span class="rm-dot rm-dot--g"></span>
                                    </div>
                                  </div>
                                  <pre class="rm-code-pre"><code>{p.detail.code.lines}</code></pre>
                                </div>
                              </div>
                              <div class="rm-det-pane" data-pane="production">
                                <div class="rm-pitfalls">
                                  {p.detail.pitfalls.map(pit => (
                                    <div class="rm-pitfall">
                                      <div class="rm-pitfall-head">
                                        <span class="rm-pit-badge">Pitfall</span>
                                        <strong class="rm-pit-issue">{pit.issue}</strong>
                                      </div>
                                      <p class="rm-pit-context">{pit.context}</p>
                                      <div class="rm-pit-fix">
                                        <span class="rm-pit-fix-badge">Fix</span>
                                        <span class="rm-pit-fix-text">{pit.fix}</span>
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              </div>
                              <div class="rm-det-pane" data-pane="qa">
                                <div class="rm-qa-list">
                                  {p.detail.qa.map(qi => (
                                    <div class="rm-qa-item">
                                      <button class="rm-qa-q" onclick="rmQA(this)" type="button">
                                        <span>{qi.q}</span>
                                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                          <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                      </button>
                                      <div class="rm-qa-a">
                                        <p>{qi.a}</p>
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              </div>
                            </div>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>

                  <blockquote class="rm-insight">{stage.insight}</blockquote>
                </div>

              </article>
            ))}
          </div>

        </section>
      ))}

      <div class="rm-end">
        <p class="rm-end-eyebrow">End of Python reference</p>
        <h2 class="rm-end-title">Now build something with it.</h2>
        <p class="rm-end-sub">Theory compounds only when it meets production code.</p>
        <div class="rm-end-actions">
          <a href="/foundations" class="btn btn-primary">All Foundations</a>
          <a href="/ai-engineering/ai-engineer-roadmap" class="btn btn-secondary">AI Engineer Roadmap</a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<style is:global>
/* Python page uses the rm-* design system from the roadmap.
   Only layer-specific insight colours are added here. */
[data-layer="core"]        .rm-insight { border-left-color: var(--sage); }
[data-layer="structures"]  .rm-insight { border-left-color: var(--terra); }
[data-layer="advanced-oop"].rm-insight { border-left-color: var(--amber); }
[data-layer="testing"]     .rm-insight { border-left-color: var(--ink3); }
[data-layer="scientific"]  .rm-insight { border-left-color: var(--sage); }
[data-layer="concurrency"] .rm-insight { border-left-color: var(--terra); }

/* btn helpers (shared with roadmap end block) */
.btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 11px 22px; border-radius: 7px;
  font-family: var(--sans); font-size: 0.84rem; font-weight: 700;
  text-decoration: none; transition: background 0.18s, transform 0.18s;
}
.btn-primary  { background: var(--ink); color: var(--linen); }
.btn-primary:hover  { background: var(--ink2); transform: translateY(-1px); }
.btn-secondary { background: transparent; color: var(--ink); border: 1px solid var(--linen3); }
.btn-secondary:hover { background: var(--linen2); }
</style>

<script is:inline>
function rmToggle(row) {
  var item = row.closest('.rm-spec-item');
  var isOpen = item.classList.contains('rm-spec-item--open');
  var spec = row.closest('.rm-spec');
  spec.querySelectorAll('.rm-spec-item--open').forEach(function(el) {
    el.classList.remove('rm-spec-item--open');
  });
  if (!isOpen) item.classList.add('rm-spec-item--open');
}

function rmTab(btn, pane) {
  var det = btn.closest('.rm-det');
  det.querySelectorAll('.rm-det-tab').forEach(function(t) {
    t.classList.remove('rm-det-tab--active');
  });
  det.querySelectorAll('.rm-det-pane').forEach(function(p) {
    p.classList.remove('rm-det-pane--active');
  });
  btn.classList.add('rm-det-tab--active');
  var target = det.querySelector('[data-pane="' + pane + '"]');
  if (target) target.classList.add('rm-det-pane--active');
}

function rmQA(btn) {
  var item = btn.closest('.rm-qa-item');
  var isOpen = item.classList.contains('rm-qa-item--open');
  var list = btn.closest('.rm-qa-list');
  list.querySelectorAll('.rm-qa-item--open').forEach(function(el) {
    el.classList.remove('rm-qa-item--open');
  });
  if (!isOpen) item.classList.add('rm-qa-item--open');
}

/* Scroll-reveal: adds rm-visible to stages as they enter the viewport */
(function() {
  var stages = Array.from(document.querySelectorAll('.rm-stage'));
  if (!stages.length) return;
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('rm-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  stages.forEach(function(s) { io.observe(s); });
})();
</script>
