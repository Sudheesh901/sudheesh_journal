A = np.random.randn(32, 128)
B = np.random.randn(32, 128)

dots   = np.einsum('ij,ij->i', A, B)    # per-row dot product → (32,)
outer  = np.einsum('i,j->ij', A[0], B[0])  # outer product → (128, 128)
matmul = np.einsum('ik,jk->ij', A, B)   # A @ B.T → (32, 32)

