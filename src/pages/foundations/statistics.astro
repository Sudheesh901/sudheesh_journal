                              </div>
                            </div>

                            <!-- Interview Q&A -->
                            <div class="rm-det-pane" data-pane="qa">
                              <div class="rm-qa-list">
                                {p.detail.qa.map(qi => (
                                  <div class="rm-qa-item">
                                    <button class="rm-qa-q" onclick="rmQA(this)" type="button">
                                      <span>{qi.q}</span>
