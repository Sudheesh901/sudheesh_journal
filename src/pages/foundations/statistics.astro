<BaseLayout
  title="Statistics & Experimentation — Sudheesh Knowledge Base"
  description="Statistical foundations for DS and AI engineers: probability, distributions, CLT, MLE, hypothesis testing, A/B testing, and causal inference — with math notation, code, ML connections, and interview Q&A at every stage."
  active="foundations"
>
  <main class="page active rm-page">

    <!-- ══ HERO ══════════════════════════════════════════════ -->
    <section class="rm-hero">
      <div class="rm-hero-inner">
        <div class="rm-hero-left">
          <div class="rm-eyebrow">
            <span class="rm-badge">Foundations</span>
            <span class="rm-badge-sep">·</span>
            <span class="rm-badge-count">12 Stages</span>
