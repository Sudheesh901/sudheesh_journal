from scipy import stats
import pandas as pd

np.random.seed(42)

# ── Compute all four moments ──────────────────────────────
def describe_moments(data, label):
    print(f"\\n{label}:")
    print(f"  Mean:     {np.mean(data):.4f}")
    print(f"  Variance: {np.var(data, ddof=1):.4f}")
    print(f"  Skewness: {stats.skew(data):.4f}")
