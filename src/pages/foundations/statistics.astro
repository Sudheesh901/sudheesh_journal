        b = roc_auc_score(y_true[idx], y_prob_B[idx])
        delta_boot.append(a - b)
ci_delta = np.percentile(delta_boot, [2.5, 97.5])
print(f"\\nΔ AUC (A−B): {roc_auc_score(y_true,y_prob_A)-roc_auc_score(y_true,y_prob_B):.4f}")
