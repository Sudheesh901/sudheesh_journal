beta_ols = np.linalg.lstsq(X_b, y, rcond=None)[0]
# lstsq is numerically stable; never invert directly with np.linalg.inv

# ── Gradient Descent from scratch ─────────────────────────
def mse_gradient(X, y, beta):
    n = len(y)
    residuals = X @ beta - y
    return (2 / n) * X.T @ residuals

