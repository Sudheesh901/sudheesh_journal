g = grads[0]
# Second derivative (Hessian diagonal)
hess = torch.autograd.grad(g.sum(), x)[0]              # ∂²y/∂x² = 2
print(f"\\n∂y/∂x   = {grads[0].tolist()}")   # [2x₀, 2x₁, 2x₂, 2x₃]
