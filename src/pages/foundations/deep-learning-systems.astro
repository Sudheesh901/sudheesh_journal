<BaseLayout
  title="Deep Learning Systems — Sudheesh Knowledge Base"
  description="Deep learning systems from MLP basics to production deployment: backprop, optimizers, regularisation, CNNs, Transformers, mixed precision, LoRA, quantization — with PyTorch code, engineering patterns, and interview Q&A at every stage."
  active="foundations"
>
  <main class="page active rm-page">

    <!-- ══ HERO ══════════════════════════════════════════════ -->
    <section class="rm-hero">
      <div class="rm-hero-inner">
        <div class="rm-hero-left">
          <div class="rm-eyebrow">
            <span class="rm-badge">Foundations</span>
            <span class="rm-badge-sep">·</span>
            <span class="rm-badge-count">12 Stages</span>
          </div>
          <h1 class="rm-hero-title">
            <span class="rm-ht-sans">Deep Learning</span>
            <span class="rm-ht-serif">Systems.</span>
          </h1>
          <p class="rm-hero-desc">
            From perceptron to production — backprop, optimizers, CNNs, Transformers, LoRA, quantization, and MLOps, built for engineers who ship models, not just train them.
          </p>
          <div class="rm-hero-tools">
            <span class="rm-tool-pill">PyTorch</span><span class="rm-tool-pill">JAX</span><span class="rm-tool-pill">HuggingFace</span><span class="rm-tool-pill">PEFT</span><span class="rm-tool-pill">bitsandbytes</span><span class="rm-tool-pill">ONNX</span><span class="rm-tool-pill">TensorRT</span><span class="rm-tool-pill">WandB</span><span class="rm-tool-pill">torchvision</span>
          </div>
        </div>

        <nav class="rm-hero-index" aria-label="Stage index">
          {layers.map(layer => (
            <div class="rm-idx-layer">
              <div class="rm-idx-layer-label" data-layer={layer.id}>
                {layer.label} <span class="rm-idx-range">{layer.range}</span>
              </div>
              {layer.stages.map(stage => (
                <a class="rm-idx-item" href={`#stage-${stage.num}`}>
                  <span class="rm-idx-num">{stage.num}</span>
                  <span class="rm-idx-title">{stage.title}</span>
                </a>
              ))}
            </div>
          ))}
        </nav>
      </div>
    </section>

    <!-- ══ BODY ══════════════════════════════════════════════ -->
    <div class="rm-body">

      {layers.map(layer => (
        <section class="rm-layer" data-layer={layer.id}>
          <div class="rm-layer-head">
            <div class="rm-lh-line"></div>
            <div class="rm-lh-label">
              <span class="rm-lh-name">{layer.label}</span>
              <span class="rm-lh-range">{layer.range}</span>
            </div>
            <div class="rm-lh-line"></div>
          </div>

          <div class="rm-track">
            {layer.stages.map(stage => (
              <article class="rm-stage" id={`stage-${stage.num}`}>
                <div class="rm-stage-gutter">
                  <div class="rm-stage-dot"></div>
                  <div class="rm-stage-num">{stage.num}</div>
                </div>
                <div class="rm-stage-content">
                  <h2 class="rm-stage-title">{stage.title}</h2>
                  <p class="rm-stage-intro">{stage.intro}</p>

                  <div class="rm-spec">
                    {stage.points.map(p => (
                      <div class="rm-spec-item">
                        <div class="rm-spec-row rm-spec-row--has-detail" onclick="rmToggle(this)">
                          <div class="rm-spec-term">{p.term}</div>
                          <div class="rm-spec-desc">{p.desc}</div>
                          <div class="rm-spec-chevron" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                              <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </div>
                        </div>

                        <div class="rm-det">
                          <nav class="rm-det-tabs">
                            <button class="rm-det-tab rm-det-tab--active" onclick="rmTab(this,'overview')" type="button">Overview</button>
                            <button class="rm-det-tab" onclick="rmTab(this,'code')" type="button">Code</button>
                            <button class="rm-det-tab" onclick="rmTab(this,'prod')" type="button">In Production</button>
                            <button class="rm-det-tab" onclick="rmTab(this,'qa')" type="button">Interview Q&amp;A</button>
                          </nav>

                          <div class="rm-det-body">

                            <!-- Overview + optional diagram -->
                            <div class="rm-det-pane rm-det-pane--active" data-pane="overview">
                              <p class="rm-det-overview">{p.detail.overview}</p>
                              {p.detail.diagram && (
                                <pre class="rm-diagram">{p.detail.diagram}</pre>
                              )}
                            </div>

                            <!-- Code -->
                            <div class="rm-det-pane" data-pane="code">
                              <div class="rm-code">
                                <div class="rm-code-bar">
                                  <span class="rm-code-lang">{p.detail.code.label}</span>
                                  <div class="rm-code-dots">
                                    <span class="rm-dot rm-dot--r"></span>
                                    <span class="rm-dot rm-dot--y"></span>
                                    <span class="rm-dot rm-dot--g"></span>
                                  </div>
                                </div>
                                <pre class="rm-code-pre"><code>{p.detail.code.lines}</code></pre>
                              </div>
                            </div>

                            <!-- In Production -->
                            <div class="rm-det-pane" data-pane="prod">
                              <div class="rm-pitfalls">
                                <div class="rm-dsai-link">
                                  <span class="rm-dsai-badge">In Production</span>
                                  <span class="rm-dsai-text">{p.detail.prod.prodLink}</span>
                                </div>
                                {p.detail.prod.traps.map(trap => (
                                  <div class="rm-pitfall">
                                    <div class="rm-pitfall-head">
                                      <span class="rm-pit-badge">Trap</span>
                                      <strong class="rm-pit-issue">{trap.issue}</strong>
                                    </div>
                                    <p class="rm-pit-context">{trap.context}</p>
                                    <div class="rm-pit-fix">
                                      <span class="rm-pit-fix-badge">Fix</span>
                                      <span class="rm-pit-fix-text">{trap.fix}</span>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>

                            <!-- Interview Q&A -->
                            <div class="rm-det-pane" data-pane="qa">
                              <div class="rm-qa-list">
                                {p.detail.qa.map(qi => (
                                  <div class="rm-qa-item">
                                    <button class="rm-qa-q" onclick="rmQA(this)" type="button">
                                      <span>{qi.q}</span>
                                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                    </button>
                                    <div class="rm-qa-a"><p>{qi.a}</p></div>
                                  </div>
                                ))}
                              </div>
                            </div>

                          </div>
                        </div>
                      </div>
                    ))}
                  </div>

                  <blockquote class="rm-insight">{stage.insight}</blockquote>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <div class="rm-end">
        <p class="rm-end-eyebrow">Deep Learning Systems — Complete</p>
        <h2 class="rm-end-title">From perceptrons to production.</h2>
        <p class="rm-end-sub">12 stages across neural net foundations, training mechanics, regularisation, architectures, scale, and deployment.</p>
        <div class="rm-end-actions">
          <a href="/foundations" class="btn btn-primary">All Foundations</a>
          <a href="/foundations/ai-ml" class="btn btn-secondary">AI/ML Foundations</a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

