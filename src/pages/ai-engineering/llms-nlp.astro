---
import BaseLayout from '@/layouts/BaseLayout.astro';

const layers = [
  {
    id: 'foundation',
    label: 'Language Foundations',
    range: '01-04',
    stages: [
      {
        num: '01',
        title: 'Text, Corpus, and Vocabulary',
        intro: 'Start with the raw material of NLP: messy text, documents, labels, and the vocabulary built from them.',
        insight: 'Most language-system failures begin before the model call: bad parsing, weak labels, missing metadata, or a corpus that does not represent the real task.',
        points: [
          {
            term: 'Corpus Design',
            desc: 'Documents, utterances, domains, train-test splits, leakage, sampling, metadata, and representative coverage.',
            detail: {
              overview: 'A corpus is the collection of text a system learns from, searches over, evaluates on, or uses as grounding evidence. Good corpus design starts with task boundaries: who writes the text, what language and format it uses, which domains matter, and what future examples must not leak into training or evaluation. For interview revision, always connect corpus quality to downstream metrics because bad data can make even a strong model look unstable.',
              code: {
                label: 'Python - stratified split sketch',
                lines: `from sklearn.model_selection import train_test_split

train, test = train_test_split(
    examples,
    test_size=0.2,
    stratify=[x["label"] for x in examples],
    random_state=42,
)
assert not set(x["doc_id"] for x in train) & set(x["doc_id"] for x in test)`
              },
              pitfalls: [
                { issue: 'Document leakage across splits', context: 'Chunks from the same source document appear in both train and test, inflating accuracy and hiding generalization failures.', fix: 'Split by document, user, account, or time depending on the production boundary.' },
                { issue: 'Evaluation corpus does not match production', context: 'The test set uses clean English tickets, but production includes OCR, tables, abbreviations, and multilingual text.', fix: 'Sample eval data from real traces and maintain slices for language, source, length, and domain.' }
              ],
              qa: [
                { q: 'What is a corpus in NLP?', a: 'A corpus is a collection of text examples used for training, retrieval, evaluation, analysis, or grounding.' },
                { q: 'How do you avoid data leakage in NLP?', a: 'Split by the unit that repeats in production, such as document, user, conversation, company, or time window, not only by individual row.' },
                { q: 'Why is metadata part of corpus quality?', a: 'Metadata enables filtering, slicing, access control, debugging, recency handling, and fair evaluation across subgroups.' }
              ]
            }
          },
          {
            term: 'Vocabulary + N-grams',
            desc: 'Unigrams, bigrams, phrase features, out-of-vocabulary terms, domain terms, and vocabulary pruning.',
            detail: {
              overview: 'Before neural embeddings, NLP systems represented text using vocabulary features. N-grams still matter for search, classification baselines, spam detection, log analysis, and exact term matching. They capture surface patterns that dense embeddings can miss, especially IDs, error codes, product names, and rare legal or medical terms. A strong learning path understands these baselines before jumping to LLMs.',
              code: {
                label: 'Python - TF-IDF baseline',
                lines: `from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression

vec = TfidfVectorizer(ngram_range=(1, 2), min_df=2, max_features=50000)
X = vec.fit_transform([x["text"] for x in train])
clf = LogisticRegression(max_iter=1000).fit(X, [x["label"] for x in train])`
              },
              pitfalls: [
                { issue: 'Skipping the baseline', context: 'A team ships an expensive LLM classifier without knowing whether TF-IDF plus logistic regression would meet the SLA.', fix: 'Build lexical and small-model baselines before choosing an LLM-heavy architecture.' },
                { issue: 'Vocabulary too broad or too narrow', context: 'Keeping every token overfits noise; pruning too aggressively removes rare but important terms.', fix: 'Tune min_df, max_df, and n-gram range against validation slices.' }
              ],
              qa: [
                { q: 'What is an n-gram?', a: 'A contiguous sequence of n tokens. A unigram is one token, a bigram is two, and a trigram is three.' },
                { q: 'Why can TF-IDF still beat embeddings?', a: 'It is strong for exact terms, rare identifiers, domain jargon, and small labeled datasets where semantic generalization is less important.' },
                { q: 'What is OOV?', a: 'Out-of-vocabulary means a token or term was not seen during vocabulary construction and may be ignored or mapped to an unknown feature.' }
              ]
            }
          },
          {
            term: 'Text Normalization',
            desc: 'Unicode cleanup, sentence segmentation, casing, punctuation, stop words, stemming, lemmatization, and domain dictionaries.',
            detail: {
              overview: 'Normalization turns messy text into a more consistent form, but over-normalization can destroy meaning. Preserve negation, IDs, section numbers, currency, code symbols, capitalization, and table structure when they matter. Modern LLM and embedding models usually prefer natural text, so aggressive stemming and stop-word removal should be justified by evals, not habit.',
              code: {
                label: 'Python - conservative normalizer',
                lines: `import re
import unicodedata

def normalize_text(text: str) -> str:
    text = unicodedata.normalize("NFKC", text)
    text = re.sub(r"\\s+", " ", text).strip()
    text = text.replace("smart-phone", "smartphone")
    return text`
              },
              pitfalls: [
                { issue: 'Removing negation as a stop word', context: 'The sentence "not eligible for refund" becomes "eligible refund", reversing the meaning.', fix: 'Use task-specific stop-word lists and test negation-heavy cases.' },
                { issue: 'English-only preprocessing', context: 'Whitespace rules, stemming, and sentence splitting fail on multilingual or code-mixed inputs.', fix: 'Detect language and use language-aware tokenization or avoid destructive preprocessing.' }
              ],
              qa: [
                { q: 'Stemming vs lemmatization?', a: 'Stemming chops words to crude roots; lemmatization maps words to dictionary forms using linguistic knowledge.' },
                { q: 'Should you lowercase everything?', a: 'Not always. Lowercase can help lexical matching, but it can damage acronyms, IDs, named entities, and case-sensitive code.' },
                { q: 'What should be stored after normalization?', a: 'Store raw text, normalized text, source metadata, offsets, and the normalizer version.' }
              ]
            }
          }
        ]
      },
      {
        num: '02',
        title: 'Classical NLP Tasks and Labels',
        intro: 'Learn the task vocabulary that still appears in modern LLM product work.',
        insight: 'LLMs often wrap classical NLP tasks in natural language, but the product still needs labels, spans, metrics, and failure analysis.',
        points: [
          {
            term: 'Core Tasks',
            desc: 'Classification, sentiment, NER, POS tagging, parsing, relation extraction, summarization, and clustering.',
            detail: {
              overview: 'Classical NLP tasks define what the system should do with text. Classification assigns labels. NER extracts entity spans. Relation extraction connects entities. POS tagging and parsing expose grammatical structure. Summarization compresses information. Clustering groups similar texts. LLMs can perform many of these zero-shot, but production systems still need schemas, labeled examples, and measurable outputs.',
              code: {
                label: 'Task schema examples',
                lines: `ticket = {
  "label": "billing_issue",
  "entities": [
    {"type": "invoice_id", "text": "INV-2041", "start": 17, "end": 25}
  ],
  "sentiment": "frustrated"
}`
              },
              pitfalls: [
                { issue: 'Vague label definitions', context: 'Annotators cannot distinguish complaint, escalation, urgent, and churn risk consistently.', fix: 'Write label guidelines with examples, counterexamples, and conflict rules.' },
                { issue: 'Entity extraction without normalization', context: 'The system extracts "NYC", "New York", and "New York City" but cannot connect them.', fix: 'Add entity linking to canonical IDs after span extraction.' }
              ],
              qa: [
                { q: 'What is NER?', a: 'Named entity recognition identifies spans such as people, companies, products, dates, amounts, and IDs.' },
                { q: 'What is relation extraction?', a: 'It identifies relationships between extracted entities, such as company acquired company or ticket references invoice.' },
                { q: 'When is a rule-based NLP system acceptable?', a: 'When the language pattern is stable, the risk of false positives is low, and deterministic behavior is more valuable than broad generalization.' }
              ]
            }
          },
          {
            term: 'Labeling Quality',
            desc: 'Annotation guidelines, inter-annotator agreement, label noise, class imbalance, active learning, and review loops.',
            detail: {
              overview: 'A model cannot learn a task that humans cannot label consistently. Labeling quality depends on clear guidelines, calibrated annotators, disagreement review, representative samples, and careful handling of rare classes. For LLM systems, labeled data is still needed for evals, prompt regression, fine-tuning, routing, and human preference optimization.',
              code: {
                label: 'Python - label distribution check',
                lines: `from collections import Counter

counts = Counter(x["label"] for x in examples)
total = sum(counts.values())
for label, n in counts.most_common():
    print(label, n, round(n / total, 3))`
              },
              pitfalls: [
                { issue: 'Optimizing overall accuracy on imbalanced labels', context: 'A model gets 96% accuracy by always predicting the majority class and misses rare fraud cases.', fix: 'Track precision, recall, and F1 per class, especially for high-risk labels.' },
                { issue: 'No disagreement workflow', context: 'Annotator conflicts are hidden in the data and become confusing training signal.', fix: 'Review disagreements, update guidelines, and keep adjudicated labels separate from raw labels.' }
              ],
              qa: [
                { q: 'What is inter-annotator agreement?', a: 'A measure of how consistently different annotators label the same examples.' },
                { q: 'What is active learning?', a: 'A labeling strategy that prioritizes uncertain or high-value examples for human annotation.' },
                { q: 'How do you handle class imbalance?', a: 'Use stratified sampling, class-weighted losses, threshold tuning, targeted data collection, and per-class metrics.' }
              ]
            }
          },
          {
            term: 'NLP Metrics',
            desc: 'Accuracy, precision, recall, F1, exact match, BLEU, ROUGE, BERTScore, calibration, and slice analysis.',
            detail: {
              overview: 'Metrics must match the task. Classification often uses precision, recall, and F1. Extraction uses span-level exact match or partial match. Summarization may use ROUGE or human rubric scores. Semantic answer quality may use BERTScore or LLM judges, but those should be calibrated. Always inspect metrics by slice: source, language, label, length, recency, and customer segment.',
              code: {
                label: 'Python - classification metrics',
                lines: `from sklearn.metrics import classification_report

y_true = [x["label"] for x in test]
y_pred = clf.predict(vec.transform([x["text"] for x in test]))
print(classification_report(y_true, y_pred, digits=3))`
              },
              pitfalls: [
                { issue: 'One metric for every task', context: 'Accuracy hides low recall on the class that matters most to the business.', fix: 'Choose metrics based on error cost and report them per slice.' },
                { issue: 'Using BLEU or ROUGE as truth', context: 'Surface overlap can punish good paraphrases and reward copied but incomplete text.', fix: 'Use them as weak signals with human or rubric-based checks for important tasks.' }
              ],
              qa: [
                { q: 'Precision vs recall?', a: 'Precision asks how many predicted positives were correct. Recall asks how many actual positives were found.' },
                { q: 'What is F1?', a: 'The harmonic mean of precision and recall, useful when both false positives and false negatives matter.' },
                { q: 'Why do slice metrics matter?', a: 'A model can look good overall while failing on a language, customer group, document type, or rare label.' }
              ]
            }
          }
        ]
      },
      {
        num: '03',
        title: 'Sparse Retrieval and Lexical Search',
        intro: 'Understand exact-match retrieval before semantic retrieval and RAG.',
        insight: 'Dense embeddings are powerful, but sparse search remains the fastest way to catch names, IDs, error codes, versions, and rare terms.',
        points: [
          {
            term: 'Inverted Index',
            desc: 'Term dictionaries, postings lists, document frequency, field boosts, filters, and phrase matching.',
            detail: {
              overview: 'An inverted index maps each term to the documents containing it. This powers search engines, log search, compliance discovery, and the sparse side of hybrid RAG. It is explainable, fast, filter-friendly, and strong for exact terms. Learn it before vector search because many production retrieval bugs are actually lexical matching or metadata filtering bugs.',
              code: {
                label: 'Python - tiny inverted index',
                lines: `from collections import defaultdict

index = defaultdict(set)
for doc_id, text in docs.items():
    for term in text.lower().split():
        index[term].add(doc_id)

matches = index["refund"] & index["policy"]`
              },
              pitfalls: [
                { issue: 'No field-aware search', context: 'A match in the footer ranks above a match in the title or policy heading.', fix: 'Boost important fields such as title, heading, ID, and canonical entity fields.' },
                { issue: 'Ignoring analyzers', context: 'The search engine tokenizes IDs, hyphens, accents, and case differently than expected.', fix: 'Test analyzer output for real queries and domain terms.' }
              ],
              qa: [
                { q: 'What is an inverted index?', a: 'A structure that maps terms to the documents or positions where those terms occur.' },
                { q: 'Why is lexical search important in RAG?', a: 'It catches exact identifiers and rare terms that semantic search may smooth away.' },
                { q: 'What are postings lists?', a: 'Lists of documents, and often positions, where a term appears.' }
              ]
            }
          },
          {
            term: 'TF-IDF and BM25',
            desc: 'Term frequency, inverse document frequency, document length normalization, scoring, and ranking baselines.',
            detail: {
              overview: 'TF-IDF scores terms higher when they are frequent in a document but rare in the corpus. BM25 improves lexical ranking with saturation and document-length normalization. These methods are strong baselines for search, classification, and hybrid retrieval. In interviews, BM25 is a useful contrast against embeddings: exactness and explainability versus semantic generalization.',
              code: {
                label: 'BM25 scoring intuition',
                lines: `score(query, doc) =
  sum(
    idf(term) *
    tf_saturation(term, doc) *
    length_normalization(doc)
    for term in query
  )`
              },
              pitfalls: [
                { issue: 'Dense-only retrieval for identifiers', context: 'A query for ERR-8492 returns semantically similar troubleshooting docs but misses the exact error page.', fix: 'Use BM25 or exact filters alongside vector search.' },
                { issue: 'Not tuning analyzers and boosts', context: 'BM25 performs poorly because tokenization and field weights do not match the domain.', fix: 'Tune analyzers, synonyms, field boosts, and query parsing with labeled retrieval data.' }
              ],
              qa: [
                { q: 'BM25 vs TF-IDF?', a: 'Both use term rarity, but BM25 adds better term-frequency saturation and document-length normalization for ranking.' },
                { q: 'When does BM25 beat embeddings?', a: 'Exact IDs, rare names, error codes, quotes, legal clauses, and queries where lexical precision matters.' },
                { q: 'What is IDF?', a: 'Inverse document frequency gives more weight to terms that appear in fewer documents.' }
              ]
            }
          },
          {
            term: 'Hybrid Search',
            desc: 'Sparse plus dense retrieval, Reciprocal Rank Fusion, metadata filters, query expansion, and reranking.',
            detail: {
              overview: 'Hybrid search combines lexical precision with semantic recall. A common production pattern retrieves candidates from BM25 and vector search, filters by permissions and metadata, fuses or reranks the candidates, then sends only the strongest evidence to the model. This is the bridge from classical search to modern RAG.',
              code: {
                label: 'Python - reciprocal rank fusion',
                lines: `def rrf(rankings, k=60):
    scores = {}
    for ranking in rankings:
        for rank, doc_id in enumerate(ranking, start=1):
            scores[doc_id] = scores.get(doc_id, 0) + 1 / (k + rank)
    return sorted(scores, key=scores.get, reverse=True)`
              },
              pitfalls: [
                { issue: 'Fusion before permission filters', context: 'Unauthorized documents influence ranking or leak through traces.', fix: 'Apply ACL filters before ranking results are shown or used.' },
                { issue: 'Reranking too few candidates', context: 'The right document was not in the truncated top ten from either retriever.', fix: 'Retrieve a wider candidate pool, then rerank and trim.' }
              ],
              qa: [
                { q: 'What is Reciprocal Rank Fusion?', a: 'A simple method that combines multiple ranked lists by giving each document credit based on its rank in each list.' },
                { q: 'Why use hybrid search?', a: 'It improves recall across semantic queries and exact lexical queries.' },
                { q: 'Where does reranking fit?', a: 'After initial retrieval and filtering, before final prompt assembly.' }
              ]
            }
          }
        ]
      },
      {
        num: '04',
        title: 'Embeddings and Semantic Similarity',
        intro: 'Move from lexical overlap to meaning-based retrieval and clustering.',
        insight: 'Embeddings are similarity features, not truth. They need versioning, evaluation, and retrieval guardrails.',
        points: [
          {
            term: 'Embedding Space',
            desc: 'Vector representations, cosine similarity, normalization, pooling, dimensions, and semantic neighborhoods.',
            detail: {
              overview: 'Embeddings represent text as vectors so semantically related items land near each other. They are useful for semantic search, duplicate detection, clustering, routing, recommendations, and RAG. Similarity is task-dependent: the nearest vector can be topically related but outdated, unauthorized, or not actually answerable.',
              code: {
                label: 'Python - runnable cosine search',
                lines: `import numpy as np

texts = ["refund policy", "invoice payment", "password reset"]
vectors = np.array([[1.0, 0.1], [0.1, 1.0], [0.8, 0.2]])
query = np.array([0.9, 0.1])

def normalize(x):
    return x / np.linalg.norm(x, axis=-1, keepdims=True)

scores = normalize(vectors) @ normalize(query).reshape(-1, 1)
best = int(scores.argmax())
print(texts[best])`
              },
              pitfalls: [
                { issue: 'Comparing vectors from different models', context: 'Scores become meaningless when old and new embedding spaces are mixed.', fix: 'Store embedding model, dimension, preprocessing, and index build version.' },
                { issue: 'Assuming nearest means correct', context: 'The closest chunk is similar but not sufficient evidence for the answer.', fix: 'Rerank, check answerability, and validate generated claims against source text.' }
              ],
              qa: [
                { q: 'What is cosine similarity?', a: 'A measure of angle between vectors, often used to compare embedding direction after normalization.' },
                { q: 'What does embedding dimension mean?', a: 'The number of numeric coordinates in the vector representation.' },
                { q: 'How do you evaluate embeddings?', a: 'Use retrieval recall@k, MRR, clustering quality, duplicate detection F1, and human relevance labels.' }
              ]
            }
          },
          {
            term: 'Vector Indexing',
            desc: 'ANN search, HNSW, IVF, recall-latency trade-offs, metadata filters, and index rebuilds.',
            detail: {
              overview: 'Vector databases use approximate nearest-neighbor indexes to find similar vectors quickly. Approximation creates a recall-latency trade-off: faster search may miss relevant documents. Production systems must evaluate retrieval quality after index tuning, not only model quality. Metadata filters and ACLs must be part of the retrieval plan, not an afterthought.',
              code: {
                label: 'Index config checklist',
                lines: `vector_index = {
  "embedding_model": "text-embedding-model",
  "dimensions": 1536,
  "metric": "cosine",
  "ann": "hnsw",
  "filters": ["tenant_id", "acl", "doc_type", "created_at"]
}`
              },
              pitfalls: [
                { issue: 'Tuning for latency only', context: 'The index gets faster but misses the expected evidence for hard questions.', fix: 'Track recall@k and latency together during index tuning.' },
                { issue: 'Post-filtering after vector search', context: 'The top vector results are removed by ACL filters, leaving too few candidates.', fix: 'Prefer pre-filtering or retrieve a larger candidate pool before filtering.' }
              ],
              qa: [
                { q: 'What is ANN search?', a: 'Approximate nearest-neighbor search trades perfect recall for much faster vector lookup.' },
                { q: 'What is HNSW?', a: 'A graph-based ANN index commonly used for fast high-recall vector search.' },
                { q: 'Why do metadata filters matter?', a: 'They enforce permissions, recency, source type, tenant boundaries, and domain constraints.' }
              ]
            }
          },
          {
            term: 'Model Selection',
            desc: 'Rules, classical ML, encoder models, LLM APIs, open-source LLMs, cost, privacy, latency, and eval-driven choice.',
            detail: {
              overview: 'A senior NLP engineer chooses the simplest model that satisfies the product contract. Rules are best for stable exact policies. Classical ML is strong for high-volume labeled tasks. Encoder models are efficient for classification and embeddings. LLMs are best for nuanced language, reasoning, flexible schemas, and explanation. Open-source models help with privacy and control but add infrastructure burden.',
              code: {
                label: 'Decision rubric',
                lines: `if exact_policy and stable_pattern:
    choice = "rules"
elif many_labels and strict_latency:
    choice = "small classifier or encoder"
elif needs_reasoning or changing_schema:
    choice = "LLM with evals"
elif data_cannot_leave_vpc:
    choice = "self-hosted model"`
              },
              pitfalls: [
                { issue: 'Choosing by benchmark leaderboard only', context: 'The best general model is too slow, costly, or weak on private domain data.', fix: 'Benchmark on your own eval set with latency, cost, safety, and failure-mode criteria.' },
                { issue: 'Ignoring operational ownership', context: 'A self-hosted model meets privacy needs but the team cannot operate GPUs, scaling, or updates.', fix: 'Include infrastructure and support cost in model selection.' }
              ],
              qa: [
                { q: 'API LLM vs open-source LLM?', a: 'API models reduce ops burden and often lead capability; open-source models offer control, privacy, customization, and cost advantages at scale.' },
                { q: 'When use a small classifier instead of an LLM?', a: 'For stable, high-throughput, low-latency tasks with enough labeled data.' },
                { q: 'What is the right model-selection process?', a: 'Define task metrics, build baselines, evaluate candidates on real cases, then choose by quality, cost, latency, privacy, and maintainability.' }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    id: 'foundation',
    label: 'Model Foundations',
    range: '05-08',
    stages: [
      {
        num: '05',
        title: 'Transformer Architecture',
        intro: 'Understand the inference machine before designing systems around it.',
        insight: 'Most LLM bugs are easier to debug when you can separate model limitation, prompt limitation, retrieval limitation, and product-contract limitation.',
        points: [
          {
            term: 'Tokenization',
            desc: 'Subword boundaries, vocabulary effects, multilingual behavior, prompt cost, and lossless reconstruction.',
            detail: {
              overview: 'Tokenization is the compression boundary between text and model. It shapes cost, context length, latency, and behavior around code, rare names, IDs, tables, and non-English text. Production systems should measure token growth after prompt assembly, not only raw character length, because repeated schema instructions, citations, and tool traces can silently consume the usable context window.',
              code: {
                label: 'Python - token-budget guard',
                lines: `def reserve_budget(messages, max_context, max_output, tokenizer):
    used = sum(len(tokenizer.encode(m["content"])) for m in messages)
    available = max_context - max_output
    if used > available:
        raise ValueError(f"Prompt uses {used} tokens; budget is {available}")
    return {"prompt_tokens": used, "remaining": available - used}`
              },
              pitfalls: [
                { issue: 'Counting characters instead of tokens', context: 'A short JSON schema or code block can tokenize far worse than prose. The app passes tests on normal text, then fails on legal clauses, tables, logs, and code snippets.', fix: 'Budget after final prompt assembly with the target model tokenizer and reserve output tokens explicitly.' },
                { issue: 'Ignoring tokenizer changes during model migration', context: 'A model switch can change token count, truncation behavior, and cost without any product UI changing.', fix: 'Add token-budget regression tests for representative prompts before changing model families.' }
              ],
              qa: [
                { q: 'Why does tokenization matter for product reliability?', a: 'It controls what the model can actually see. If the system truncates the wrong context, the model may answer confidently from incomplete evidence.' },
                { q: 'What should be logged for token debugging?', a: 'Log prompt tokens, completion tokens, model name, truncation strategy, selected documents, and final prompt template version.' }
              ]
            }
          },
          {
            term: 'Attention + KV Cache',
            desc: 'Why long prompts are expensive and why streaming, batching, and prefix reuse matter.',
            detail: {
              overview: 'Self-attention creates queries, keys, and values from token representations. A query asks what this token needs, keys describe what other tokens offer, and values carry the information to mix back in. Multi-head attention repeats this in parallel. During generation, the KV cache stores computed key/value states so the model does not recompute the full prefix at each step. Long input contexts increase prefill latency; long outputs increase decode latency.',
              code: {
                label: 'Attention and latency sketch',
                lines: `Q = X @ Wq
K = X @ Wk
V = X @ Wv
attention = softmax((Q @ K.T) / sqrt(d_k)) @ V

total_latency = prefill(context_tokens) + decode(output_tokens)`
              },
              pitfalls: [
                { issue: 'Optimizing only generation length', context: 'Teams cap max output but keep sending 40 retrieved chunks and a huge policy block. The user still experiences slow first-token latency.', fix: 'Measure time-to-first-token separately from total completion time and tune retrieval depth, compression, and prompt prefix reuse.' },
                { issue: 'Treating context window as free memory', context: 'A 128k context window can still be too slow, too expensive, and too noisy for a specific task.', fix: 'Use the smallest context that preserves task accuracy, then prove it with evals.' }
              ],
              qa: [
                { q: 'What are Q, K, and V in attention?', a: 'Queries represent what a token is looking for, keys represent what each token can match on, and values carry the information that gets mixed into the output.' },
                { q: 'What is prefill?', a: 'Prefill is the phase where the model processes the input prompt and builds KV cache state before emitting the first token.' },
                { q: 'Why do long RAG prompts often reduce quality?', a: 'They introduce distractors, conflicting snippets, and higher instruction dilution. More context is not automatically better context.' }
              ]
            }
          },
          {
            term: 'Decoding',
            desc: 'Temperature, top-p, penalties, stop sequences, JSON mode, and structured outputs.',
            detail: {
              overview: 'Decoding converts model probabilities into text. Deterministic settings help extraction, classification, and tool calls; moderate randomness helps brainstorming and rewrites. Structured outputs reduce parser failures, but they do not guarantee semantic correctness. The production contract is: generate, validate, repair or escalate.',
              code: {
                label: 'Python - Pydantic structured output',
                lines: `from pydantic import BaseModel, Field, ValidationError

class Invoice(BaseModel):
    invoice_id: str
    amount_due: float = Field(ge=0)
    currency: str

try:
    invoice = Invoice.model_validate(model_json)
except ValidationError as err:
    raise ValueError(f"invalid model output: {err}")`
              },
              pitfalls: [
                { issue: 'Using high temperature for factual QA', context: 'Randomness can make valid retrieval grounding less stable and make regressions harder to reproduce.', fix: 'Use low temperature for grounded answers, extraction, routing, and tool arguments.' },
                { issue: 'Trusting JSON validity as truth', context: 'The object parses, but fields can still be unsupported by evidence or violate business logic.', fix: 'Run schema validation, evidence checks, and domain rules after parsing.' }
              ],
              qa: [
                { q: 'When should temperature be close to zero?', a: 'Use it for classification, extraction, compliance responses, deterministic routing, and any path where reproducibility matters more than creative variation.' },
                { q: 'What are stop sequences good for?', a: 'They constrain generation boundaries, especially in older prompt formats, but they should not replace schema validation.' }
              ]
            }
          }
        ]
      },
      {
        num: '06',
        title: 'Prompting as Interface Design',
        intro: 'Prompts are not magic words. They are executable specifications for a probabilistic worker.',
        insight: 'A good prompt is boring in the best way: clear task, clear inputs, clear constraints, clear output, clear failure behavior.',
        points: [
          {
            term: 'Prompt Contract',
            desc: 'Role, task, context, rules, output schema, refusal policy, and examples only when they remove ambiguity.',
            detail: {
