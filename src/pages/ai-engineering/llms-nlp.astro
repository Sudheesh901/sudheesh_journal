<script is:inline>
function lnlpToggle(row) {
  var item = row.closest('.lnlp-spec-item');
  var isOpen = item.classList.contains('lnlp-spec-item--open');
  var spec = row.closest('.lnlp-spec');
  spec.querySelectorAll('.lnlp-spec-item--open').forEach(function (el) {
    el.classList.remove('lnlp-spec-item--open');
  });
  if (!isOpen) item.classList.add('lnlp-spec-item--open');
}

function lnlpTab(btn, pane) {
  var det = btn.closest('.lnlp-det');
  det.querySelectorAll('.lnlp-det-tab').forEach(function (t) { t.classList.remove('lnlp-det-tab--active'); });
  det.querySelectorAll('.lnlp-det-pane').forEach(function (p) { p.classList.remove('lnlp-det-pane--active'); });
  btn.classList.add('lnlp-det-tab--active');
  var target = det.querySelector('[data-pane="' + pane + '"]');
  if (target) target.classList.add('lnlp-det-pane--active');
}

function lnlpQA(btn) {
  var item = btn.closest('.lnlp-qa-item');
  var isOpen = item.classList.contains('lnlp-qa-item--open');
  var list = btn.closest('.lnlp-qa-list');
  list.querySelectorAll('.lnlp-qa-item--open').forEach(function (el) { el.classList.remove('lnlp-qa-item--open'); });
  if (!isOpen) item.classList.add('lnlp-qa-item--open');
}

(function () {
  var stages = document.querySelectorAll('.lnlp-stage');
  if (!stages.length) return;
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('lnlp-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.05 });
  stages.forEach(function (s) { io.observe(s); });
})();
</script>
