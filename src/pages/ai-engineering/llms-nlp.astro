          </div>

          <div class="lnlp-track">
            {layer.stages.map(stage => (
              <article class="lnlp-stage" id={`stage-${stage.num}`}>
                <div class="lnlp-stage-gutter">
                  <div class="lnlp-stage-dot"></div>
                  <div class="lnlp-stage-num">{stage.num}</div>
                </div>

                <div class="lnlp-stage-content">
                  <h2 class="lnlp-stage-title">{stage.title}</h2>
                  <p class="lnlp-stage-intro">{stage.intro}</p>

                  <div class="lnlp-spec">
                    {stage.points.map(point => (
                      <div class="lnlp-spec-item">
                        <button class="lnlp-spec-row" onclick="lnlpToggle(this)" type="button">
                          <span class="lnlp-spec-term">{point.term}</span>
                          <span class="lnlp-spec-desc">{point.desc}</span>
                          <span class="lnlp-spec-chevron" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                              <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                          </span>
                        </button>

                        <div class="lnlp-det">
                          <nav class="lnlp-det-tabs">
                            <button class="lnlp-det-tab lnlp-det-tab--active" onclick="lnlpTab(this,'overview')" type="button">Overview</button>
                            <button class="lnlp-det-tab" onclick="lnlpTab(this,'code')" type="button">Code</button>
                            <button class="lnlp-det-tab" onclick="lnlpTab(this,'production')" type="button">In Production</button>
                            <button class="lnlp-det-tab" onclick="lnlpTab(this,'qa')" type="button">Interview Q&A</button>
                          </nav>
                          <div class="lnlp-det-body">
                            <div class="lnlp-det-pane lnlp-det-pane--active" data-pane="overview">
                              <p class="lnlp-det-overview">{point.detail.overview}</p>
                            </div>
                            <div class="lnlp-det-pane" data-pane="code">
                              <div class="lnlp-code">
                                <div class="lnlp-code-bar">
                                  <span class="lnlp-code-lang">{point.detail.code.label}</span>
                                  <div class="lnlp-code-dots"><span></span><span></span><span></span></div>
                                </div>
                                <pre class="lnlp-code-pre"><code>{point.detail.code.lines}</code></pre>
                              </div>
                            </div>
                            <div class="lnlp-det-pane" data-pane="production">
                              <div class="lnlp-pitfalls">
                                {point.detail.pitfalls.map(pit => (
                                  <div class="lnlp-pitfall">
                                    <div class="lnlp-pitfall-head">
                                      <span class="lnlp-pit-badge">Pitfall</span>
                                      <strong>{pit.issue}</strong>
                                    </div>
                                    <p>{pit.context}</p>
                                    <div class="lnlp-pit-fix">
                                      <span>Fix</span>
                                      <em>{pit.fix}</em>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>
                            <div class="lnlp-det-pane" data-pane="qa">
                              <div class="lnlp-qa-list">
                                {point.detail.qa.map(item => (
                                  <div class="lnlp-qa-item">
                                    <button class="lnlp-qa-q" onclick="lnlpQA(this)" type="button">
                                      <span>{item.q}</span>
                                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                      </svg>
                                    </button>
                                    <div class="lnlp-qa-a"><p>{item.a}</p></div>
                                  </div>
                                ))}
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>

                  <blockquote class="lnlp-insight">{stage.insight}</blockquote>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <div class="lnlp-end">
        <p class="lnlp-end-eyebrow">Operating principle</p>
        <h2 class="lnlp-end-title">Evaluate before you elaborate.</h2>
        <p class="lnlp-end-sub">The difference between a demo and a system is not a larger prompt. It is measured behavior, controlled cost, and recoverable failure.</p>
      </div>
    </div>
  </main>
</BaseLayout>

