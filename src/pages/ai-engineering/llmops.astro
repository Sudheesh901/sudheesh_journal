              ],
              qa: [
                { q: 'What is the minimum viable incident response setup for a 3-person LLM team?', a: 'Minimum viable: (1) PagerDuty integration with Prometheus alert for LLM error_rate > 5% (P1) and P99 latency > 5s (P2). (2) LiteLLM with 2 providers configured (OpenAI primary, Anthropic secondary) — failover is automatic. (3) A Slack #incidents channel where PagerDuty alerts post. (4) A one-page runbook: Detect (check Grafana) → Isolate (query structured logs: which provider/feature?) → Failover (update LiteLLM config or restart with secondary) → Communicate (Slack message). (5) Monthly rotation of on-call responsibility. This costs < 2 hours to set up and prevents the most common failure mode (provider outage = product outage).' },
                { q: 'How do you structure a post-mortem for an LLM-specific incident?', a: 'LLM post-mortem template: (1) Incident summary: what failed, when, how long, user impact (N users affected, revenue impact if applicable). (2) Timeline: minute-by-minute from first alert to resolution — include detection lag, response time, and recovery time. (3) Root cause analysis (5-Whys): start from the user-visible symptom and ask why 5 times. (4) LLM-specific contributing factors: Was it a prompt change? Model upgrade? Data drift? Provider issue? Retrieval failure? (5) Detection gaps: why did it take N minutes to detect? What monitoring would have caught it sooner? (6) Action items: each item has an owner, a due date, and a clear definition of done. (7) Metrics: MTTR, MTTD, SLA impact. Publish within 48 hours — share with the broader team for learning.' },
                { q: 'How do you automate API key rotation for multiple LLM providers without service interruption?', a: 'Zero-downtime rotation procedure: (1) Generate a new API key at the provider. (2) Add the new key to AWS Secrets Manager as a new secret version (the old version remains active). (3) LiteLLM reads keys from env vars injected by the Secrets Manager agent — update the env var to point to the new version. (4) Rolling restart: K8s rolls out a new LiteLLM pod that picks up the new key. During the rollout, old pods use the old key and new pods use the new key — both work simultaneously. (5) After all pods are updated (5 minutes), revoke the old key at the provider. (6) Verify: test an API call with the new key from a monitoring pod. Automate this with a GitHub Actions workflow on a monthly schedule: generate key → store in Secrets Manager → trigger K8s rollout → revoke old key → verify.' }
              ]
            }
          }
        ]
      }
    ]
  },
];
---
<BaseLayout
  title="LLMOps — Sudheesh Knowledge Base"
  description="LLMOps reference: prompt engineering, LLM serving, RAG evaluation, observability, fine-tuning, guardrails, and provider reliability."
  active="ai-engineering"
>
  <main class="page active llo-page">

    <section class="llo-hero">
      <div class="llo-hero-inner">

        <div class="llo-hero-left">
          <div class="llo-eyebrow">
            <span class="llo-badge">AI Engineering</span>
            <span class="llo-badge-sep">/</span>
            <span class="llo-badge-count">LLMOps</span>
          </div>
          <h1 class="llo-hero-title">
            <span class="llo-ht-sans">LLM</span>
            <span class="llo-ht-serif">Operations.</span>
          </h1>
          <p class="llo-hero-desc">
            A production guide to operating large language models at scale: prompt versioning, context management, self-hosted serving, RAG pipelines, observability, fine-tuning, guardrails, and provider reliability — everything between a capable model and a trustworthy system.
          </p>
          <div class="llo-hero-tools">
            {tools.map(t => <span class="llo-tool-pill">{t}</span>)}
          </div>
        </div>

        <nav class="llo-hero-index" aria-label="LLMOps stage index">
          {layers.map(layer => (
            <div class="llo-idx-layer">
              <div class="llo-idx-layer-label" data-layer={layer.id}>
                {layer.label}
                <span class="llo-idx-range">{layer.range}</span>
              </div>
              {layer.stages.map(stage => (
                <a class="llo-idx-item" href={`#stage-${stage.num}`}>
                  <span class="llo-idx-num">{stage.num}</span>
                  <span class="llo-idx-title">{stage.title}</span>
                </a>
              ))}
            </div>
          ))}
        </nav>

      </div>
    </section>

    <div class="llo-body">
      {layers.map(layer => (
        <section class="llo-layer" data-layer={layer.id}>

          <div class="llo-layer-head">
            <div class="llo-lh-line"></div>
            <div class="llo-lh-label">
              <span class="llo-lh-name">{layer.label}</span>
              <span class="llo-lh-range">{layer.range}</span>
            </div>
            <div class="llo-lh-line"></div>
          </div>

          <div class="llo-track">
            {layer.stages.map(stage => (
              <article class="llo-stage" id={`stage-${stage.num}`}>

                <div class="llo-stage-gutter">
                  <div class="llo-stage-dot"></div>
                  <div class="llo-stage-num">{stage.num}</div>
                </div>

                <div class="llo-stage-content">
                  <h2 class="llo-stage-title">{stage.title}</h2>
                  <p class="llo-stage-intro">{stage.intro}</p>

                  <div class="llo-spec">
                    {stage.points.map(point => (
                      <div class="llo-spec-item">
                        <button class="llo-spec-row" onclick="lloToggle(this)" type="button">
                          <span class="llo-spec-term">{point.term}</span>
                          <span class="llo-spec-desc">{point.desc}</span>
                          <span class="llo-spec-chevron" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                              <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                          </span>
                        </button>

                        <div class="llo-det">
                          <nav class="llo-det-tabs">
                            <button class="llo-det-tab llo-det-tab--active" onclick="lloTab(this,'overview')"    type="button">Overview</button>
                            <button class="llo-det-tab"                      onclick="lloTab(this,'code')"        type="button">Code</button>
                            <button class="llo-det-tab"                      onclick="lloTab(this,'production')"  type="button">In Production</button>
                            <button class="llo-det-tab"                      onclick="lloTab(this,'qa')"          type="button">Interview Q&amp;A</button>
                          </nav>
                          <div class="llo-det-body">

                            <div class="llo-det-pane llo-det-pane--active" data-pane="overview">
                              <p class="llo-det-overview">{point.detail.overview}</p>
                            </div>

                            <div class="llo-det-pane" data-pane="code">
                              <div class="llo-code">
                                <div class="llo-code-bar">
                                  <span class="llo-code-lang">{point.detail.code.label}</span>
                                  <div class="llo-code-dots"><span></span><span></span><span></span></div>
                                </div>
                                <pre class="llo-code-pre"><code>{point.detail.code.lines}</code></pre>
                              </div>
                            </div>

                            <div class="llo-det-pane" data-pane="production">
                              <div class="llo-pitfalls">
                                {point.detail.pitfalls.map(pit => (
                                  <div class="llo-pitfall">
                                    <div class="llo-pitfall-head">
                                      <span class="llo-pit-badge">Pitfall</span>
                                      <strong>{pit.issue}</strong>
                                    </div>
                                    <p>{pit.context}</p>
                                    <div class="llo-pit-fix">
                                      <span>Fix</span>
                                      <em>{pit.fix}</em>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>

                            <div class="llo-det-pane" data-pane="qa">
                              <div class="llo-qa-list">
                                {point.detail.qa.map(item => (
                                  <div class="llo-qa-item">
                                    <button class="llo-qa-q" onclick="lloQA(this)" type="button">
                                      <span>{item.q}</span>
                                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                      </svg>
                                    </button>
                                    <div class="llo-qa-a"><p>{item.a}</p></div>
                                  </div>
                                ))}
                              </div>
                            </div>

                          </div>
                        </div>
                      </div>
                    ))}
                  </div>

                  <blockquote class="llo-insight">{stage.insight}</blockquote>
                </div>

              </article>
            ))}
          </div>

        </section>
      ))}

      <div class="llo-end">
        <p class="llo-end-eyebrow">Operating principle</p>
        <h2 class="llo-end-title">Observability scales trust.</h2>
        <p class="llo-end-sub">Every untraced prompt, every unchecked output, every unmonitored cost is an incident waiting to happen. Instrument everything, evaluate continuously, and the model becomes a reliable component — not a liability.</p>
      </div>
    </div>

  </main>
</BaseLayout>

<style is:global>
.llo-page { background: var(--linen); padding-top: 0; }
.llo-hero { padding-top: var(--nav-h); border-bottom: 1px solid var(--linen3); }
.llo-hero-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 36px 80px 52px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.llo-eyebrow { display: flex; align-items: center; gap: 8px; margin-bottom: 22px; }
.llo-badge {
  font-family: var(--mono);
  font-size: 0.63rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--terra);
  background: var(--terra-pale);
  border: 1px solid rgba(196,97,74,0.22);
  padding: 4px 10px;
  border-radius: 4px;
}
.llo-badge-sep   { color: var(--linen3); font-size: 0.8rem; }
.llo-badge-count { font-family: var(--mono); font-size: 0.62rem; color: var(--muted2); letter-spacing: 0.1em; text-transform: uppercase; }
.llo-hero-title  { display: flex; flex-direction: column; margin-bottom: 24px; line-height: 0.93; }
.llo-ht-sans {
  font-family: var(--sans);
  font-size: clamp(3rem, 5.5vw, 5.6rem);
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -0.045em;
}
.llo-ht-serif {
  font-family: var(--display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(3rem, 5.5vw, 5.6rem);
  color: var(--terra);
  letter-spacing: -0.03em;
}
.llo-hero-desc  { font-size: clamp(0.95rem, 1.2vw, 1.08rem); color: var(--muted); line-height: 1.75; max-width: 520px; margin-bottom: 28px; }
.llo-hero-tools { display: flex; flex-wrap: wrap; gap: 6px; }
.llo-tool-pill  {
  font-family: var(--mono);
  font-size: 0.64rem;
  color: var(--muted2);
  background: var(--linen2);
  border: 1px solid var(--linen3);
  padding: 4px 10px;
  border-radius: 4px;
  letter-spacing: 0.04em;
}
.llo-hero-index { border-left: 1px solid var(--linen3); padding-left: clamp(28px, 4vw, 56px); display: flex; flex-direction: column; gap: 28px; }
.llo-idx-layer-label {
  font-family: var(--mono);
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.llo-idx-range  { font-weight: 400; color: var(--muted2); letter-spacing: 0.06em; }
[data-layer="prompts"]      .llo-idx-layer-label { color: var(--sage); }
[data-layer="serving"]      .llo-idx-layer-label { color: var(--terra); }
[data-layer="rag"]          .llo-idx-layer-label { color: var(--amber); }
[data-layer="observability"].llo-idx-layer-label { color: var(--ink3); }
[data-layer="finetuning"]   .llo-idx-layer-label { color: var(--sage); }
[data-layer="guardrails"]   .llo-idx-layer-label { color: var(--terra); }
.llo-idx-item   { display: flex; align-items: baseline; gap: 10px; text-decoration: none; padding: 3px 0; }
.llo-idx-num    { font-family: var(--mono); font-size: 0.58rem; color: var(--muted2); letter-spacing: 0.06em; flex-shrink: 0; }
.llo-idx-title  { font-size: 0.8rem; color: var(--ink2); line-height: 1.4; transition: color 0.15s; }
.llo-idx-item:hover .llo-idx-title { color: var(--ink); }

/* body */
.llo-body { max-width: 1280px; margin: 0 auto; padding: 0 80px 120px; }

/* layer header */
.llo-layer { margin-top: 80px; }
.llo-layer-head { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 20px; margin-bottom: 48px; }
.llo-lh-line    { height: 1px; background: var(--linen3); }
.llo-lh-label   { display: flex; flex-direction: column; align-items: center; gap: 4px; text-align: center; }
.llo-lh-name    { font-family: var(--mono); font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink2); }
.llo-lh-range   { font-family: var(--mono); font-size: 0.58rem; color: var(--muted2); letter-spacing: 0.06em; }

/* stage track */
.llo-track      { display: flex; flex-direction: column; gap: 40px; position: relative; }
.llo-track::before { content: ''; position: absolute; left: 27px; top: 0; bottom: 0; width: 1px; background: var(--linen3); }
.llo-stage      { display: flex; gap: 32px; opacity: 0; transform: translateY(16px); transition: opacity 0.5s ease, transform 0.5s ease; }
.llo-stage.llo-visible { opacity: 1; transform: translateY(0); }
.llo-stage-gutter { flex: 0 0 56px; width: 56px; display: flex; flex-direction: column; align-items: center; padding-top: 4px; }
.llo-stage-dot  { width: 12px; height: 12px; border-radius: 50%; background: var(--linen3); border: 2px solid var(--linen); flex-shrink: 0; position: relative; z-index: 1; }
.llo-stage-num  { font-family: var(--mono); font-size: 0.58rem; color: var(--muted2); letter-spacing: 0.06em; margin-top: 6px; }
.llo-stage-content { flex: 1; min-width: 0; padding-bottom: 40px; }
.llo-stage-title { font-family: var(--sans); font-size: clamp(1.05rem, 1.4vw, 1.22rem); font-weight: 700; color: var(--ink); letter-spacing: -0.02em; margin-bottom: 10px; line-height: 1.3; }
.llo-stage-intro { font-size: 0.875rem; color: var(--muted); line-height: 1.8; max-width: 780px; margin-bottom: 28px; }

/* layer dot colour */
[data-layer="prompts"]      .llo-stage-dot { background: var(--sage); }
[data-layer="serving"]      .llo-stage-dot { background: var(--terra); }
[data-layer="rag"]          .llo-stage-dot { background: var(--amber); }
[data-layer="observability"].llo-stage-dot { background: var(--ink3); }
[data-layer="finetuning"]   .llo-stage-dot { background: var(--sage); }
[data-layer="guardrails"]   .llo-stage-dot { background: var(--terra); }

/* spec table */
.llo-spec       { border: 1px solid var(--linen3); border-radius: 10px; overflow: hidden; margin-bottom: 24px; }
.llo-spec-item  { border-bottom: 1px solid var(--linen3); }
.llo-spec-item:last-child { border-bottom: none; }
.llo-spec-row   {
  display: grid;
  grid-template-columns: minmax(180px,220px) 1fr 40px;
  width: 100%; text-align: left; background: none; border: none; cursor: pointer;
  padding: 0; transition: background 0.15s;
}
.llo-spec-row:hover { background: var(--linen2); }
.llo-spec-item--open .llo-spec-row { background: var(--linen2); }
.llo-spec-term  { font-family: var(--mono); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; color: var(--ink); padding: 14px 16px; border-right: 1px solid var(--linen3); line-height: 1.4; display: flex; align-items: center; }
.llo-spec-desc  { font-size: 0.8rem; color: var(--muted); padding: 14px 16px; display: flex; align-items: center; line-height: 1.5; }
.llo-spec-chevron { display: flex; align-items: center; justify-content: center; color: var(--muted2); transition: transform 0.22s ease; }
.llo-spec-item--open .llo-spec-chevron { transform: rotate(180deg); }

/* detail panel */
.llo-det        { display: none; border-top: 1px solid var(--linen3); }
.llo-spec-item--open .llo-det { display: block; }
.llo-det-tabs   { display: flex; gap: 0; border-bottom: 1px solid var(--linen3); background: var(--linen2); }
.llo-det-tab    { font-family: var(--mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px 18px; border: none; background: none; cursor: pointer; color: var(--muted2); border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color 0.15s, border-color 0.15s; }
.llo-det-tab:hover { color: var(--ink); }
.llo-det-tab--active { color: var(--ink); border-bottom-color: var(--terra); }
.llo-det-body   { }
.llo-det-pane           { display: none; padding: 22px 24px; }
.llo-det-pane--active   { display: block; }
.llo-det-overview       { font-size: 0.875rem; color: var(--muted); line-height: 1.85; max-width: 760px; margin: 0; white-space: pre-wrap; }

/* code */
.llo-code               { border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); }
.llo-code-bar           { display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; background: #1c1c1e; }
.llo-code-lang          { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.11em; text-transform: uppercase; color: var(--terra2); }
.llo-code-dots          { display: flex; gap: 5px; align-items: center; }
.llo-code-dots span     { width: 10px; height: 10px; border-radius: 50%; }
.llo-code-dots span:nth-child(1) { background: #FF5F57; }
.llo-code-dots span:nth-child(2) { background: #FEBC2E; }
.llo-code-dots span:nth-child(3) { background: #28C840; }
.llo-code-pre  { margin: 0; padding: 20px 24px; background: #111113; overflow-x: auto; font-family: var(--mono); font-size: 0.78rem; line-height: 1.85; color: #C8D0E0; }
.llo-code-pre code { font-family: inherit; font-size: inherit; color: inherit; background: none; padding: 0; white-space: pre; }

/* pitfalls */
.llo-pitfalls  { display: flex; flex-direction: column; gap: 14px; }
.llo-pitfall   { border: 1px solid var(--linen3); border-radius: 8px; overflow: hidden; }
.llo-pitfall-head { display: flex; align-items: center; gap: 10px; padding: 11px 16px; background: var(--linen2); border-bottom: 1px solid var(--linen3); }
.llo-pit-badge { font-family: var(--mono); font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--amber); background: var(--amber-pale); border: 1px solid rgba(184,122,40,0.28); padding: 2px 7px; border-radius: 3px; }
.llo-pitfall strong { font-size: 0.82rem; color: var(--ink); line-height: 1.3; }
.llo-pitfall p { font-size: 0.81rem; color: var(--muted); line-height: 1.72; padding: 11px 16px; margin: 0; }
.llo-pit-fix   { display: flex; align-items: flex-start; gap: 10px; padding: 10px 16px; background: var(--sage-pale); border-top: 1px solid rgba(74,107,80,0.16); }
.llo-pit-fix span { font-family: var(--mono); font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sage); background: rgba(74,107,80,0.12); border: 1px solid rgba(74,107,80,0.25); padding: 2px 7px; border-radius: 3px; }
.llo-pit-fix em { font-size: 0.81rem; color: var(--ink2); line-height: 1.65; }

/* Q&A */
.llo-qa-list   { display: flex; flex-direction: column; gap: 8px; }
.llo-qa-item   { border: 1px solid var(--linen3); border-radius: 8px; overflow: hidden; }
.llo-qa-q      { display: flex; align-items: center; justify-content: space-between; gap: 12px; width: 100%; text-align: left; padding: 12px 16px; background: var(--linen2); border: none; cursor: pointer; font-family: var(--sans); font-size: 0.82rem; font-weight: 600; color: var(--ink); line-height: 1.45; }
.llo-qa-q:hover { background: var(--linen3); }
.llo-qa-q svg  { flex-shrink: 0; color: var(--muted2); transition: transform 0.22s ease; }
.llo-qa-item--open .llo-qa-q svg { transform: rotate(180deg); }
.llo-qa-a      { max-height: 0; overflow: hidden; transition: max-height 0.32s cubic-bezier(0.4,0,0.2,1); }
.llo-qa-item--open .llo-qa-a { max-height: 800px; }
.llo-qa-a p    { padding: 14px 16px; font-size: 0.82rem; color: var(--muted); line-height: 1.78; border-top: 1px solid var(--linen3); background: var(--white); margin: 0; }

/* key insight blockquote */
.llo-insight   { font-family: var(--display); font-style: italic; font-size: clamp(0.92rem, 1.1vw, 1.04rem); color: var(--muted); line-height: 1.7; border-left: 2px solid var(--linen3); padding-left: 16px; margin: 0; }
[data-layer="prompts"]      .llo-insight { border-left-color: var(--sage); }
[data-layer="serving"]      .llo-insight { border-left-color: var(--terra); }
[data-layer="rag"]          .llo-insight { border-left-color: var(--amber); }
[data-layer="observability"].llo-insight { border-left-color: var(--ink3); }
[data-layer="finetuning"]   .llo-insight { border-left-color: var(--sage); }
[data-layer="guardrails"]   .llo-insight { border-left-color: var(--terra); }

/* end section */
.llo-end       { text-align: center; padding: 96px 0 0; border-top: 1px solid var(--linen3); margin-top: 40px; }
.llo-end-eyebrow { font-family: var(--mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.16em; color: var(--muted2); margin-bottom: 16px; }
.llo-end-title { font-family: var(--display); font-style: italic; font-weight: 400; font-size: clamp(2.2rem, 4vw, 3.4rem); color: var(--ink); line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 10px; }
.llo-end-sub   { font-size: 0.92rem; color: var(--muted2); margin: 0 auto; max-width: 620px; line-height: 1.75; }

/* responsive */
@media (max-width: 1100px) {
  .llo-hero-inner, .llo-body { padding-left: 40px; padding-right: 40px; }
}
@media (max-width: 860px) {
  .llo-hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 48px 32px 44px; }
  .llo-hero-index { border-left: none; border-top: 1px solid var(--linen3); padding-left: 0; padding-top: 28px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px 32px; }
  .llo-body { padding-left: 32px; padding-right: 32px; }
}
@media (max-width: 560px) {
  .llo-ht-sans, .llo-ht-serif { font-size: clamp(2.4rem, 10vw, 3.2rem); }
  .llo-stage { gap: 20px; }
  .llo-stage-gutter { flex: 0 0 40px; width: 40px; }
  .llo-track::before { left: 19px; }
  .llo-spec-row { grid-template-columns: minmax(0,1fr) 36px; }
  .llo-spec-term { grid-column: 1 / -1; border-right: none; border-bottom: 1px solid var(--linen3); }
  .llo-det-pane { padding: 16px; }
  .llo-code-pre { padding: 14px 16px; font-size: 0.72rem; }
  .llo-hero-index { grid-template-columns: 1fr; }
  .llo-hero-inner, .llo-body { padding-left: 20px; padding-right: 20px; }
}
</style>

<script is:inline>
function lloToggle(row) {
  var item   = row.closest('.llo-spec-item');
  var isOpen = item.classList.contains('llo-spec-item--open');
  var spec   = row.closest('.llo-spec');
  spec.querySelectorAll('.llo-spec-item--open').forEach(function(el) { el.classList.remove('llo-spec-item--open'); });
  if (!isOpen) item.classList.add('llo-spec-item--open');
}
function lloTab(btn, pane) {
  var det = btn.closest('.llo-det');
  det.querySelectorAll('.llo-det-tab').forEach(function(t) { t.classList.remove('llo-det-tab--active'); });
  det.querySelectorAll('.llo-det-pane').forEach(function(p) { p.classList.remove('llo-det-pane--active'); });
  btn.classList.add('llo-det-tab--active');
  var target = det.querySelector('[data-pane="' + pane + '"]');
  if (target) target.classList.add('llo-det-pane--active');
}
function lloQA(btn) {
  var item   = btn.closest('.llo-qa-item');
  var isOpen = item.classList.contains('llo-qa-item--open');
  var list   = btn.closest('.llo-qa-list');
  list.querySelectorAll('.llo-qa-item--open').forEach(function(el) { el.classList.remove('llo-qa-item--open'); });
  if (!isOpen) item.classList.add('llo-qa-item--open');
}
(function() {
  var stages = document.querySelectorAll('.llo-stage');
  if (!stages.length) return;
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('llo-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.05 });
  stages.forEach(function(s) { io.observe(s); });
})();
</script>
