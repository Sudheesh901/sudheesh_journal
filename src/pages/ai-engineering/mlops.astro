.mlo-code-pre  { margin: 0; padding: 20px 24px; background: #111113; overflow-x: auto; font-family: var(--mono); font-size: 0.78rem; line-height: 1.85; color: #C8D0E0; }
.mlo-code-pre code { font-family: inherit; font-size: inherit; color: inherit; background: none; padding: 0; white-space: pre; }

/* pitfalls */
.mlo-pitfalls  { display: flex; flex-direction: column; gap: 14px; }
.mlo-pitfall   { border: 1px solid var(--linen3); border-radius: 8px; overflow: hidden; }
.mlo-pitfall-head { display: flex; align-items: center; gap: 10px; padding: 11px 16px; background: var(--linen2); border-bottom: 1px solid var(--linen3); }
.mlo-pit-badge { font-family: var(--mono); font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--amber); background: var(--amber-pale); border: 1px solid rgba(184,122,40,0.28); padding: 2px 7px; border-radius: 3px; }
.mlo-pitfall strong { font-size: 0.82rem; color: var(--ink); line-height: 1.3; }
.mlo-pitfall p { font-size: 0.81rem; color: var(--muted); line-height: 1.72; padding: 11px 16px; margin: 0; }
.mlo-pit-fix   { display: flex; align-items: flex-start; gap: 10px; padding: 10px 16px; background: var(--sage-pale); border-top: 1px solid rgba(74,107,80,0.16); }
.mlo-pit-fix span { font-family: var(--mono); font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sage); background: rgba(74,107,80,0.12); border: 1px solid rgba(74,107,80,0.25); padding: 2px 7px; border-radius: 3px; }
.mlo-pit-fix em { font-size: 0.81rem; color: var(--ink2); line-height: 1.65; }

/* Q&A */
.mlo-qa-list   { display: flex; flex-direction: column; gap: 8px; }
.mlo-qa-item   { border: 1px solid var(--linen3); border-radius: 8px; overflow: hidden; }
.mlo-qa-q      { display: flex; align-items: center; justify-content: space-between; gap: 12px; width: 100%; text-align: left; padding: 12px 16px; background: var(--linen2); border: none; cursor: pointer; font-family: var(--sans); font-size: 0.82rem; font-weight: 600; color: var(--ink); line-height: 1.45; }
.mlo-qa-q:hover { background: var(--linen3); }
.mlo-qa-q svg  { flex-shrink: 0; color: var(--muted2); transition: transform 0.22s ease; }
.mlo-qa-item--open .mlo-qa-q svg { transform: rotate(180deg); }
.mlo-qa-a      { max-height: 0; overflow: hidden; transition: max-height 0.32s cubic-bezier(0.4,0,0.2,1); }
.mlo-qa-item--open .mlo-qa-a { max-height: 800px; }
.mlo-qa-a p    { padding: 14px 16px; font-size: 0.82rem; color: var(--muted); line-height: 1.78; border-top: 1px solid var(--linen3); background: var(--white); margin: 0; }

/* key insight blockquote */
.mlo-insight   { font-family: var(--display); font-style: italic; font-size: clamp(0.92rem, 1.1vw, 1.04rem); color: var(--muted); line-height: 1.7; border-left: 2px solid var(--linen3); padding-left: 16px; margin: 0; }
[data-layer="tracking"]    .mlo-insight { border-left-color: var(--sage); }
[data-layer="cicd"]        .mlo-insight { border-left-color: var(--terra); }
[data-layer="deployment"]  .mlo-insight { border-left-color: var(--amber); }
[data-layer="monitoring"]  .mlo-insight { border-left-color: var(--ink3); }
[data-layer="features"]    .mlo-insight { border-left-color: var(--sage); }
[data-layer="reliability"] .mlo-insight { border-left-color: var(--terra); }

/* end section */
.mlo-end       { text-align: center; padding: 96px 0 0; border-top: 1px solid var(--linen3); margin-top: 40px; }
.mlo-end-eyebrow { font-family: var(--mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.16em; color: var(--muted2); margin-bottom: 16px; }
.mlo-end-title { font-family: var(--display); font-style: italic; font-weight: 400; font-size: clamp(2.2rem, 4vw, 3.4rem); color: var(--ink); line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 10px; }
.mlo-end-sub   { font-size: 0.92rem; color: var(--muted2); margin: 0 auto; max-width: 620px; line-height: 1.75; }

/* responsive */
@media (max-width: 1100px) {
  .mlo-hero-inner, .mlo-body { padding-left: 40px; padding-right: 40px; }
}
@media (max-width: 860px) {
  .mlo-hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 48px 32px 44px; }
  .mlo-hero-index { border-left: none; border-top: 1px solid var(--linen3); padding-left: 0; padding-top: 28px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px 32px; }
  .mlo-body { padding-left: 32px; padding-right: 32px; }
}
@media (max-width: 560px) {
  .mlo-ht-sans, .mlo-ht-serif { font-size: clamp(2.4rem, 10vw, 3.2rem); }
  .mlo-stage { gap: 20px; }
  .mlo-stage-gutter { flex: 0 0 40px; width: 40px; }
  .mlo-track::before { left: 19px; }
  .mlo-spec-row { grid-template-columns: minmax(0,1fr) 36px; }
  .mlo-spec-term { grid-column: 1 / -1; border-right: none; border-bottom: 1px solid var(--linen3); }
  .mlo-det-pane { padding: 16px; }
  .mlo-code-pre { padding: 14px 16px; font-size: 0.72rem; }
  .mlo-hero-index { grid-template-columns: 1fr; }
  .mlo-hero-inner, .mlo-body { padding-left: 20px; padding-right: 20px; }
}
</style>

<script is:inline>
function mloToggle(row) {
  var item   = row.closest('.mlo-spec-item');
  var isOpen = item.classList.contains('mlo-spec-item--open');
  var spec   = row.closest('.mlo-spec');
  spec.querySelectorAll('.mlo-spec-item--open').forEach(function(el) { el.classList.remove('mlo-spec-item--open'); });
  if (!isOpen) item.classList.add('mlo-spec-item--open');
}
function mloTab(btn, pane) {
  var det = btn.closest('.mlo-det');
  det.querySelectorAll('.mlo-det-tab').forEach(function(t) { t.classList.remove('mlo-det-tab--active'); });
  det.querySelectorAll('.mlo-det-pane').forEach(function(p) { p.classList.remove('mlo-det-pane--active'); });
  btn.classList.add('mlo-det-tab--active');
  var target = det.querySelector('[data-pane="' + pane + '"]');
  if (target) target.classList.add('mlo-det-pane--active');
}
function mloQA(btn) {
  var item   = btn.closest('.mlo-qa-item');
  var isOpen = item.classList.contains('mlo-qa-item--open');
  var list   = btn.closest('.mlo-qa-list');
  list.querySelectorAll('.mlo-qa-item--open').forEach(function(el) { el.classList.remove('mlo-qa-item--open'); });
  if (!isOpen) item.classList.add('mlo-qa-item--open');
}
(function() {
  var stages = document.querySelectorAll('.mlo-stage');
  if (!stages.length) return;
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('mlo-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.05 });
  stages.forEach(function(s) { io.observe(s); });
})();
</script>
