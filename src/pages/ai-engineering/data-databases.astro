                            <div class="ddb-det-pane" data-pane="code">
                              <div class="ddb-code">
                                <div class="ddb-code-bar">
                                  <span class="ddb-code-lang">{point.detail.code.label}</span>
                                  <div class="ddb-code-dots"><span></span><span></span><span></span></div>
                                </div>
                                <pre class="ddb-code-pre"><code>{point.detail.code.lines}</code></pre>
                              </div>
                            </div>
                            <div class="ddb-det-pane" data-pane="production">
                              <div class="ddb-pitfalls">
                                {point.detail.pitfalls.map(pit => (
                                  <div class="ddb-pitfall">
                                    <div class="ddb-pitfall-head">
                                      <span class="ddb-pit-badge">Pitfall</span>
                                      <strong>{pit.issue}</strong>
                                    </div>
                                    <p>{pit.context}</p>
                                    <div class="ddb-pit-fix">
                                      <span>Fix</span>
                                      <em>{pit.fix}</em>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>
                            <div class="ddb-det-pane" data-pane="qa">
                              <div class="ddb-qa-list">
                                {point.detail.qa.map(item => (
                                  <div class="ddb-qa-item">
                                    <button class="ddb-qa-q" onclick="ddbQA(this)" type="button">
                                      <span>{item.q}</span>
                                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                      </svg>
                                    </button>
                                    <div class="ddb-qa-a"><p>{item.a}</p></div>
                                  </div>
                                ))}
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>

                  <blockquote class="ddb-insight">{stage.insight}</blockquote>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <div class="ddb-end">
        <p class="ddb-end-eyebrow">Operating principle</p>
        <h2 class="ddb-end-title">Schema decisions compound.</h2>
        <p class="ddb-end-sub">A missing content_hash column, a wrong isolation level, an unindexed FK — these cost nothing to fix before launch and everything to fix after. Design the storage layer like the rest of your system depends on it, because it does.</p>
      </div>
    </div>
  </main>
</BaseLayout>

