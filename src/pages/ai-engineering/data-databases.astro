<script is:inline>
function ddbToggle(row) {
  var item   = row.closest('.ddb-spec-item');
  var isOpen = item.classList.contains('ddb-spec-item--open');
  var spec   = row.closest('.ddb-spec');
  spec.querySelectorAll('.ddb-spec-item--open').forEach(function(el) {
    el.classList.remove('ddb-spec-item--open');
  });
  if (!isOpen) item.classList.add('ddb-spec-item--open');
}

function ddbTab(btn, pane) {
  var det = btn.closest('.ddb-det');
  det.querySelectorAll('.ddb-det-tab').forEach(function(t) { t.classList.remove('ddb-det-tab--active'); });
  det.querySelectorAll('.ddb-det-pane').forEach(function(p) { p.classList.remove('ddb-det-pane--active'); });
  btn.classList.add('ddb-det-tab--active');
  var target = det.querySelector('[data-pane="' + pane + '"]');
  if (target) target.classList.add('ddb-det-pane--active');
}

function ddbQA(btn) {
  var item   = btn.closest('.ddb-qa-item');
  var isOpen = item.classList.contains('ddb-qa-item--open');
  var list   = btn.closest('.ddb-qa-list');
  list.querySelectorAll('.ddb-qa-item--open').forEach(function(el) { el.classList.remove('ddb-qa-item--open'); });
  if (!isOpen) item.classList.add('ddb-qa-item--open');
}

(function () {
  var stages = document.querySelectorAll('.ddb-stage');
  if (!stages.length) return;
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('ddb-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.05 });
  stages.forEach(function(s) { io.observe(s); });
})();
</script>
