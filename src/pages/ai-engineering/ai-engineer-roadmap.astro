  padding-left: clamp(28px, 4vw, 56px);
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.rm-idx-layer {}
.rm-idx-layer-label {
  font-family: var(--mono);
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
[data-layer="foundation"] { color: var(--sage); }
[data-layer="core-llm"]   { color: var(--terra); }
[data-layer="production"] { color: var(--amber); }
[data-layer="ship"]       { color: var(--ink); }

.rm-idx-range {
  font-weight: 400;
  color: var(--muted2);
