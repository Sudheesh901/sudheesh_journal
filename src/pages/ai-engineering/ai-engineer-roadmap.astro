.rm-code-pre code {
  font-family: inherit;
  font-size: inherit;
  color: inherit;
  background: none;
  padding: 0;
  border-radius: 0;
  white-space: pre;
}

/* ── PRODUCTION PITFALLS ──────────────────────────────────── */
.rm-pitfalls { display: flex; flex-direction: column; gap: 14px; }
.rm-pitfall {
  border: 1px solid var(--linen3);
