  margin-bottom: 28px;
}

.rm-hero-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.rm-tool-pill {
  font-family: var(--mono);
  font-size: 0.64rem;
  color: var(--muted2);
  background: var(--linen2);
  border: 1px solid var(--linen3);
  padding: 4px 10px;
  border-radius: 4px;
  letter-spacing: 0.04em;
}

/* ── hero right: stage index ── */
.rm-hero-index {
