/* ── BODY ───────────────────────────────────────────────── */
.rm-body {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 80px 140px;
}

/* ── LAYER SECTION ──────────────────────────────────────── */
.rm-layer { padding-top: 96px; }

.rm-layer-head {
  display: flex;
  align-items: center;
  gap: 18px;
  margin-bottom: 60px;
}
.rm-lh-line {
  flex: 1;
  height: 1px;
  background: var(--linen3);
}
.rm-lh-label {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.rm-lh-name {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
}
[data-layer="foundation"] .rm-lh-name { color: var(--sage); }
[data-layer="core-llm"]   .rm-lh-name { color: var(--terra); }
[data-layer="production"] .rm-lh-name { color: var(--amber); }
[data-layer="ship"]       .rm-lh-name { color: var(--ink); }

.rm-lh-range {
  font-family: var(--mono);
  font-size: 0.6rem;
  color: var(--muted2);
  letter-spacing: 0.08em;
}

/* ── TRACK + CONNECTING LINE ────────────────────────────── */
.rm-track {
  position: relative;
}

/* vertical line drawn through the gutter column center */
.rm-track::before {
  content: '';
  position: absolute;
  left: 27px;          /* center of 56px gutter */
  top: 12px;
  bottom: 60px;
  width: 1px;
  background: var(--linen3);
  z-index: 0;
}

/* ── STAGE ──────────────────────────────────────────────── */
.rm-stage {
  display: flex;
  align-items: flex-start;
  gap: 40px;
  position: relative;
  padding-bottom: 80px;
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.rm-stage.rm-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ── GUTTER (fixed-width flex child) ─────────────────────── */
.rm-stage-gutter {
  flex: 0 0 56px;
  width: 56px;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 4px;
  gap: 8px;
  position: relative;
  z-index: 1;
}

.rm-stage-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--linen);
  border: 2px solid var(--linen3);
  flex-shrink: 0;
  transition: background 0.35s, border-color 0.35s;
}
.rm-stage.rm-visible .rm-stage-dot {
  background: var(--terra-pale);
  border-color: var(--terra);
}
[data-layer="foundation"] .rm-stage.rm-visible .rm-stage-dot { background: var(--sage-pale);  border-color: var(--sage);  }
[data-layer="core-llm"]   .rm-stage.rm-visible .rm-stage-dot { background: var(--terra-pale); border-color: var(--terra); }
[data-layer="production"] .rm-stage.rm-visible .rm-stage-dot { background: var(--amber-pale); border-color: var(--amber); }
[data-layer="ship"]       .rm-stage.rm-visible .rm-stage-dot { background: var(--linen2);     border-color: var(--ink3);  }

.rm-stage-num {
  font-family: var(--mono);
  font-size: 0.64rem;
  font-weight: 700;
  color: var(--muted2);
  letter-spacing: 0.1em;
  line-height: 1;
  /* sticky within the stage as long as content is taller */
  position: sticky;
  top: calc(var(--nav-h) + 40px);
}

/* ── STAGE CONTENT (fills remaining width) ──────────────── */
.rm-stage-content {
  flex: 1;
  min-width: 0;
  width: 0; /* force flex to control width, not content */
}

.rm-stage-title {
  font-family: var(--sans);
  font-size: clamp(1.2rem, 2vw, 1.55rem);
  font-weight: 800;
  letter-spacing: -0.033em;
  color: var(--ink);
  line-height: 1.12;
  margin-bottom: 8px;
}

.rm-stage-intro {
  font-size: 0.92rem;
  color: var(--muted2);
  font-style: italic;
  line-height: 1.65;
  margin-bottom: 24px;
}

/* ── SPEC TABLE ─────────────────────────────────────────── */
.rm-spec {
  border: 1px solid var(--linen3);
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 20px;
}

/* Item wrapper — owns the separator border */
.rm-spec-item { border-bottom: 1px solid var(--linen3); }
.rm-spec-item:last-child { border-bottom: none; }

.rm-spec-row {
  display: grid;
  grid-template-columns: 190px minmax(0, 1fr);
  transition: background 0.12s;
}
.rm-spec-row--has-detail {
  grid-template-columns: 190px minmax(0, 1fr) 40px;
  cursor: pointer;
  user-select: none;
}
.rm-spec-row:hover .rm-spec-term { background: var(--linen3); }
.rm-spec-row:hover .rm-spec-desc { background: var(--linen2); }
.rm-spec-row--has-detail:hover .rm-spec-chevron { color: var(--muted); }

.rm-spec-term {
  padding: 11px 14px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--ink);
  background: var(--linen2);
  border-right: 1px solid var(--linen3);
  line-height: 1.45;
  display: flex;
  align-items: center;
}
.rm-spec-desc {
  padding: 11px 16px;
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.55;
  background: var(--linen);
  display: flex;
  align-items: center;
}
.rm-spec-chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--linen);
  color: var(--linen3);
  transition: color 0.14s;
}
.rm-spec-chevron svg { transition: transform 0.28s cubic-bezier(0.4,0,0.2,1); }
.rm-spec-item--open .rm-spec-chevron svg { transform: rotate(180deg); }
.rm-spec-item--open .rm-spec-chevron { color: var(--muted2); }

/* ── DETAIL PANEL ─────────────────────────────────────────── */
.rm-det {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.42s cubic-bezier(0.4,0,0.2,1);
  background: var(--white);
  border-top: 0;
}
.rm-spec-item--open > .rm-det { max-height: 1400px; }

/* ── DETAIL TABS ──────────────────────────────────────────── */
.rm-det-tabs {
  display: flex;
  align-items: center;
  padding: 0 20px;
  border-bottom: 1px solid var(--linen3);
  gap: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.rm-det-tabs::-webkit-scrollbar { display: none; }
.rm-det-tab {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--muted2);
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 11px 16px;
  cursor: pointer;
  transition: color 0.14s, border-color 0.14s;
  margin-bottom: -1px;
  white-space: nowrap;
}
.rm-det-tab:hover { color: var(--muted); }
.rm-det-tab--active { color: var(--sage); border-bottom-color: var(--sage); }
[data-layer="core-llm"]   .rm-det-tab--active { color: var(--terra); border-bottom-color: var(--terra); }
[data-layer="production"] .rm-det-tab--active { color: var(--amber); border-bottom-color: var(--amber); }
[data-layer="ship"]       .rm-det-tab--active { color: var(--ink3); border-bottom-color: var(--ink3); }

/* ── DETAIL PANES ─────────────────────────────────────────── */
.rm-det-pane { display: none; padding: 22px 24px; }
.rm-det-pane--active { display: block; }

.rm-det-overview {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.85;
  max-width: 700px;
  margin: 0;
}

