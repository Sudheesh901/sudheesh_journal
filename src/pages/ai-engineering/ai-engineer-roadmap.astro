          { term: 'Guardrails',           desc: 'Input/output filtering, Guardrails AI, NeMo Guardrails' },
          { term: 'Prompt injection',     desc: 'Indirect injection via retrieved documents, sandboxing' },
          { term: 'PII redaction',        desc: 'Entity recognition, masking, differential privacy' },
          { term: 'EU AI Act',            desc: 'Risk classification, documentation, prohibited use cases' },
          { term: 'Content filtering',    desc: 'Toxicity classifiers, multi-layer moderation pipelines' },
        ],
        insight: 'Compliance is cheaper to build in than retrofit.',
      },
      {
        num: '11',
        title: 'Open Source + Portfolio Ship',
        intro: 'Builders get hired. Watchers do not.',
        points: [
          { term: 'Ship publicly',     desc: 'Demo video, README, live endpoint — not a private repo' },
          { term: 'Technical writing', desc: 'Architecture decisions, failure modes, production lessons' },
          { term: 'Demo videos',       desc: 'Showing a system end-to-end is stronger than describing it' },
          { term: 'OSS contributions', desc: 'LangGraph, LlamaIndex, RAGAS — documentation PRs count' },
          { term: 'Build in public',   desc: 'Share what breaks, not just what works' },
        ],
        insight: 'A portfolio with one system that failed interestingly beats ten clean tutorial reproductions.',
      },
      {
        num: '12',
        title: 'Apply',
        intro: 'Roles that value this exact stack:',
        points: [
          { term: 'GenAI Engineer',               desc: 'Building LLM-powered products end-to-end' },
          { term: 'AI Application Developer',     desc: 'Integrating LLMs into existing product surfaces' },
          { term: 'LLM Infrastructure Engineer',  desc: 'Inference serving, fine-tuning pipelines, model ops' },
          { term: 'Autonomous Systems Engineer',  desc: 'Multi-agent systems, agentic product development' },
        ],
        insight: 'Most people stay stuck watching tutorials. Builders get hired.',
      },
    ],
  },
];

const allStages = layers.flatMap(l => l.stages);
---

<BaseLayout
  title="AI Engineer Roadmap — Sudheesh Knowledge Base"
  description="A 12-stage practical progression from Python async architecture to shipping production GenAI systems."
  active="ai-engineering"
>
  <main class="page active rm-page">

    <!-- ══ HERO ══════════════════════════════════════════════ -->
    <section class="rm-hero">
      <div class="rm-hero-inner">

        <!-- LEFT: title + description -->
        <div class="rm-hero-left">
          <div class="rm-eyebrow">
            <span class="rm-badge">AI Engineering</span>
            <span class="rm-badge-sep">·</span>
            <span class="rm-badge-count">12 Stages</span>
          </div>

          <h1 class="rm-hero-title">
            <span class="rm-ht-sans">AI Engineer</span>
            <span class="rm-ht-serif">Roadmap.</span>
          </h1>

          <p class="rm-hero-desc">
            A practical progression from Python async architecture to shipping production GenAI systems — and landing the role.
          </p>

          <div class="rm-hero-tools">
            {['FastAPI','LangGraph','vLLM','RAGAS','LlamaIndex','DeepEval'].map(t => (
              <span class="rm-tool-pill">{t}</span>
            ))}
          </div>
        </div>

        <!-- RIGHT: stage index — fills the empty panel with real content -->
        <nav class="rm-hero-index" aria-label="Stage index">
          {layers.map(layer => (
            <div class="rm-idx-layer">
              <div class="rm-idx-layer-label" data-layer={layer.id}>
                {layer.label}
                <span class="rm-idx-range">{layer.range}</span>
              </div>
              {layer.stages.map(stage => (
                <a class="rm-idx-item" href={`#stage-${stage.num}`}>
                  <span class="rm-idx-num">{stage.num}</span>
                  <span class="rm-idx-title">{stage.title}</span>
                </a>
              ))}
            </div>
          ))}
        </nav>

      </div>
    </section>

    <!-- ══ ROADMAP BODY ═══════════════════════════════════════ -->
    <div class="rm-body">

      {layers.map(layer => (
        <section class="rm-layer" data-layer={layer.id}>

          <!-- layer divider -->
          <div class="rm-layer-head">
            <div class="rm-lh-line"></div>
            <div class="rm-lh-label">
              <span class="rm-lh-name">{layer.label}</span>
              <span class="rm-lh-range">{layer.range}</span>
            </div>
            <div class="rm-lh-line"></div>
          </div>

          <!-- stage track -->
          <div class="rm-track">
            {layer.stages.map(stage => (
              <article class="rm-stage" id={`stage-${stage.num}`}>

                <!--
                  FIX: gutter is IN FLOW (not absolutely positioned)
                  so grid places content in the correct 1fr column.
                -->
                <div class="rm-stage-gutter">
                  <div class="rm-stage-dot"></div>
                  <div class="rm-stage-num">{stage.num}</div>
                </div>

                <div class="rm-stage-content">
                  <h2 class="rm-stage-title">{stage.title}</h2>
                  <p class="rm-stage-intro">{stage.intro}</p>

                  <div class="rm-spec">
                    {stage.points.map((p) => (
                      <div class="rm-spec-item">
                        <div
                          class:list={['rm-spec-row', p.detail && 'rm-spec-row--has-detail']}
                          onclick={p.detail ? 'rmToggle(this)' : undefined}
                        >
                          <div class="rm-spec-term">{p.term}</div>
                          <div class="rm-spec-desc">{p.desc}</div>
                          {p.detail && (
                            <div class="rm-spec-chevron" aria-hidden="true">
                              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </div>
                          )}
                        </div>
                        {p.detail && (
                          <div class="rm-det">
                            <nav class="rm-det-tabs">
                              <button class="rm-det-tab rm-det-tab--active" onclick="rmTab(this,'overview')" type="button">Overview</button>
                              <button class="rm-det-tab" onclick="rmTab(this,'code')" type="button">Code</button>
                              <button class="rm-det-tab" onclick="rmTab(this,'production')" type="button">In Production</button>
                              <button class="rm-det-tab" onclick="rmTab(this,'qa')" type="button">Interview Q&amp;A</button>
                            </nav>
                            <div class="rm-det-body">
                              <div class="rm-det-pane rm-det-pane--active" data-pane="overview">
                                <p class="rm-det-overview">{p.detail.overview}</p>
                              </div>
                              <div class="rm-det-pane" data-pane="code">
                                <div class="rm-code">
                                  <div class="rm-code-bar">
                                    <span class="rm-code-lang">{p.detail.code.label}</span>
                                    <div class="rm-code-dots">
                                      <span class="rm-dot rm-dot--r"></span>
                                      <span class="rm-dot rm-dot--y"></span>
                                      <span class="rm-dot rm-dot--g"></span>
                                    </div>
                                  </div>
                                  <pre class="rm-code-pre"><code>{p.detail.code.lines}</code></pre>
                                </div>
                              </div>
                              <div class="rm-det-pane" data-pane="production">
                                <div class="rm-pitfalls">
                                  {p.detail.pitfalls.map(pit => (
                                    <div class="rm-pitfall">
                                      <div class="rm-pitfall-head">
                                        <span class="rm-pit-badge">Pitfall</span>
                                        <strong class="rm-pit-issue">{pit.issue}</strong>
                                      </div>
                                      <p class="rm-pit-context">{pit.context}</p>
                                      <div class="rm-pit-fix">
                                        <span class="rm-pit-fix-badge">Fix</span>
                                        <span class="rm-pit-fix-text">{pit.fix}</span>
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              </div>
                              <div class="rm-det-pane" data-pane="qa">
                                <div class="rm-qa-list">
                                  {p.detail.qa.map(qi => (
                                    <div class="rm-qa-item">
                                      <button class="rm-qa-q" onclick="rmQA(this)" type="button">
                                        <span>{qi.q}</span>
                                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                          <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                      </button>
                                      <div class="rm-qa-a">
                                        <p>{qi.a}</p>
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              </div>
                            </div>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>

                  <blockquote class="rm-insight">{stage.insight}</blockquote>
                </div>

              </article>
            ))}
          </div>

        </section>
      ))}

      <!-- end block -->
      <div class="rm-end">
        <p class="rm-end-eyebrow">End of roadmap</p>
        <h2 class="rm-end-title">Builders get hired.</h2>
        <p class="rm-end-sub">Most people stay stuck watching tutorials.</p>
        <div class="rm-end-actions">
          <a href="/ai-engineering" class="btn btn-primary">Explore AI Engineering</a>
          <a href="/contact" class="btn btn-secondary">Let's collaborate</a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<style is:global>

/* ═══════════════════════════════════════════════════════════
   ROADMAP PAGE  ·  /ai-engineering/ai-engineer-roadmap
═══════════════════════════════════════════════════════════ */

/* Cancel .page's padding-top — rm-hero handles it directly */
.rm-page { background: var(--linen); padding-top: 0; }

/* ── HERO ───────────────────────────────────────────────── */
.rm-hero {
  padding-top: var(--nav-h);
  border-bottom: 1px solid var(--linen3);
}

.rm-hero-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 36px 80px 52px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* ── hero left ── */
.rm-hero-left {}

.rm-eyebrow {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 22px;
}
.rm-badge {
  font-family: var(--mono);
  font-size: 0.63rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--terra);
  background: var(--terra-pale);
  border: 1px solid rgba(196,97,74,0.22);
  padding: 4px 10px;
  border-radius: 4px;
}
.rm-badge-sep { color: var(--linen3); font-size: 0.8rem; }
.rm-badge-count {
  font-family: var(--mono);
  font-size: 0.62rem;
  color: var(--muted2);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.rm-hero-title {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 24px;
  line-height: 0.93;
}
.rm-ht-sans {
  font-family: var(--sans);
  font-size: clamp(3rem, 5.5vw, 5.6rem);
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -0.045em;
}
.rm-ht-serif {
  font-family: var(--display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(3rem, 5.5vw, 5.6rem);
  color: var(--terra);
  letter-spacing: -0.03em;
}

.rm-hero-desc {
  font-size: clamp(0.95rem, 1.2vw, 1.08rem);
  color: var(--muted);
  line-height: 1.75;
  max-width: 480px;
  margin-bottom: 28px;
}

.rm-hero-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.rm-tool-pill {
  font-family: var(--mono);
  font-size: 0.64rem;
  color: var(--muted2);
  background: var(--linen2);
  border: 1px solid var(--linen3);
  padding: 4px 10px;
  border-radius: 4px;
  letter-spacing: 0.04em;
}

/* ── hero right: stage index ── */
.rm-hero-index {
  border-left: 1px solid var(--linen3);
  padding-left: clamp(28px, 4vw, 56px);
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.rm-idx-layer {}
.rm-idx-layer-label {
  font-family: var(--mono);
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
[data-layer="foundation"] { color: var(--sage); }
[data-layer="core-llm"]   { color: var(--terra); }
[data-layer="production"] { color: var(--amber); }
[data-layer="ship"]       { color: var(--ink); }

.rm-idx-range {
  font-weight: 400;
  color: var(--muted2);
  letter-spacing: 0.06em;
}

.rm-idx-item {
  display: flex;
  align-items: baseline;
  gap: 12px;
  padding: 5px 8px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.14s;
}
.rm-idx-item:hover { background: var(--linen2); }
.rm-idx-num {
  font-family: var(--mono);
  font-size: 0.58rem;
  color: var(--muted2);
  flex-shrink: 0;
  letter-spacing: 0.06em;
}
.rm-idx-title {
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.4;
  transition: color 0.14s;
}
.rm-idx-item:hover .rm-idx-title { color: var(--ink); }

/* ── BODY ───────────────────────────────────────────────── */
.rm-body {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 80px 140px;
}

/* ── LAYER SECTION ──────────────────────────────────────── */
.rm-layer { padding-top: 96px; }

.rm-layer-head {
  display: flex;
  align-items: center;
  gap: 18px;
  margin-bottom: 60px;
}
.rm-lh-line {
  flex: 1;
  height: 1px;
  background: var(--linen3);
}
.rm-lh-label {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.rm-lh-name {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
}
[data-layer="foundation"] .rm-lh-name { color: var(--sage); }
[data-layer="core-llm"]   .rm-lh-name { color: var(--terra); }
[data-layer="production"] .rm-lh-name { color: var(--amber); }
[data-layer="ship"]       .rm-lh-name { color: var(--ink); }

.rm-lh-range {
  font-family: var(--mono);
  font-size: 0.6rem;
  color: var(--muted2);
  letter-spacing: 0.08em;
}

/* ── TRACK + CONNECTING LINE ────────────────────────────── */
.rm-track {
  position: relative;
}

/* vertical line drawn through the gutter column center */
.rm-track::before {
  content: '';
  position: absolute;
  left: 27px;          /* center of 56px gutter */
  top: 12px;
  bottom: 60px;
  width: 1px;
  background: var(--linen3);
  z-index: 0;
}

/* ── STAGE ──────────────────────────────────────────────── */
.rm-stage {
  display: flex;
  align-items: flex-start;
  gap: 40px;
  position: relative;
  padding-bottom: 80px;
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.rm-stage.rm-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ── GUTTER (fixed-width flex child) ─────────────────────── */
.rm-stage-gutter {
  flex: 0 0 56px;
  width: 56px;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 4px;
  gap: 8px;
  position: relative;
  z-index: 1;
}

.rm-stage-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--linen);
  border: 2px solid var(--linen3);
  flex-shrink: 0;
  transition: background 0.35s, border-color 0.35s;
}
.rm-stage.rm-visible .rm-stage-dot {
  background: var(--terra-pale);
  border-color: var(--terra);
}
[data-layer="foundation"] .rm-stage.rm-visible .rm-stage-dot { background: var(--sage-pale);  border-color: var(--sage);  }
[data-layer="core-llm"]   .rm-stage.rm-visible .rm-stage-dot { background: var(--terra-pale); border-color: var(--terra); }
[data-layer="production"] .rm-stage.rm-visible .rm-stage-dot { background: var(--amber-pale); border-color: var(--amber); }
[data-layer="ship"]       .rm-stage.rm-visible .rm-stage-dot { background: var(--linen2);     border-color: var(--ink3);  }

.rm-stage-num {
  font-family: var(--mono);
  font-size: 0.64rem;
  font-weight: 700;
  color: var(--muted2);
  letter-spacing: 0.1em;
  line-height: 1;
  /* sticky within the stage as long as content is taller */
  position: sticky;
  top: calc(var(--nav-h) + 40px);
}

/* ── STAGE CONTENT (fills remaining width) ──────────────── */
.rm-stage-content {
  flex: 1;
  min-width: 0;
  width: 0; /* force flex to control width, not content */
}

.rm-stage-title {
  font-family: var(--sans);
  font-size: clamp(1.2rem, 2vw, 1.55rem);
  font-weight: 800;
  letter-spacing: -0.033em;
  color: var(--ink);
  line-height: 1.12;
  margin-bottom: 8px;
}

.rm-stage-intro {
  font-size: 0.92rem;
  color: var(--muted2);
  font-style: italic;
  line-height: 1.65;
  margin-bottom: 24px;
}

/* ── SPEC TABLE ─────────────────────────────────────────── */
.rm-spec {
  border: 1px solid var(--linen3);
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 20px;
}

/* Item wrapper — owns the separator border */
.rm-spec-item { border-bottom: 1px solid var(--linen3); }
.rm-spec-item:last-child { border-bottom: none; }

.rm-spec-row {
  display: grid;
  grid-template-columns: 190px minmax(0, 1fr);
  transition: background 0.12s;
}
.rm-spec-row--has-detail {
  grid-template-columns: 190px minmax(0, 1fr) 40px;
  cursor: pointer;
  user-select: none;
}
.rm-spec-row:hover .rm-spec-term { background: var(--linen3); }
.rm-spec-row:hover .rm-spec-desc { background: var(--linen2); }
.rm-spec-row--has-detail:hover .rm-spec-chevron { color: var(--muted); }

.rm-spec-term {
  padding: 11px 14px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--ink);
  background: var(--linen2);
  border-right: 1px solid var(--linen3);
  line-height: 1.45;
  display: flex;
  align-items: center;
}
.rm-spec-desc {
  padding: 11px 16px;
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.55;
  background: var(--linen);
  display: flex;
  align-items: center;
}
.rm-spec-chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--linen);
  color: var(--linen3);
  transition: color 0.14s;
}
.rm-spec-chevron svg { transition: transform 0.28s cubic-bezier(0.4,0,0.2,1); }
.rm-spec-item--open .rm-spec-chevron svg { transform: rotate(180deg); }
.rm-spec-item--open .rm-spec-chevron { color: var(--muted2); }

/* ── DETAIL PANEL ─────────────────────────────────────────── */
.rm-det {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.42s cubic-bezier(0.4,0,0.2,1);
  background: var(--white);
  border-top: 0;
}
.rm-spec-item--open > .rm-det { max-height: 1400px; }

/* ── DETAIL TABS ──────────────────────────────────────────── */
.rm-det-tabs {
  display: flex;
  align-items: center;
  padding: 0 20px;
  border-bottom: 1px solid var(--linen3);
  gap: 0;
}
.rm-det-tab {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--muted2);
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 11px 16px;
  cursor: pointer;
  transition: color 0.14s, border-color 0.14s;
  margin-bottom: -1px;
  white-space: nowrap;
}
.rm-det-tab:hover { color: var(--muted); }
.rm-det-tab--active { color: var(--sage); border-bottom-color: var(--sage); }
[data-layer="core-llm"]   .rm-det-tab--active { color: var(--terra); border-bottom-color: var(--terra); }
[data-layer="production"] .rm-det-tab--active { color: var(--amber); border-bottom-color: var(--amber); }
[data-layer="ship"]       .rm-det-tab--active { color: var(--ink3); border-bottom-color: var(--ink3); }

/* ── DETAIL PANES ─────────────────────────────────────────── */
.rm-det-pane { display: none; padding: 22px 24px; }
.rm-det-pane--active { display: block; }

.rm-det-overview {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.85;
  max-width: 700px;
  margin: 0;
}

/* ── CODE BLOCK ───────────────────────────────────────────── */
.rm-code {
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.05);
}
.rm-code-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  background: #1c1c1e;
}
.rm-code-lang {
  font-family: var(--mono);
  font-size: 0.6rem;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  color: var(--sage);
}
[data-layer="core-llm"]   .rm-code-lang { color: var(--terra2); }
[data-layer="production"] .rm-code-lang { color: var(--amber); }
[data-layer="ship"]       .rm-code-lang { color: var(--muted2); }
.rm-code-dots { display: flex; gap: 5px; align-items: center; }
.rm-dot { width: 10px; height: 10px; border-radius: 50%; }
.rm-dot--r { background: #FF5F57; }
.rm-dot--y { background: #FEBC2E; }
.rm-dot--g { background: #28C840; }
.rm-code-pre {
  margin: 0;
  padding: 20px 24px;
  background: #111113;
  overflow-x: auto;
  font-family: var(--mono);
  font-size: 0.78rem;
  line-height: 1.85;
  color: #C8D0E0;
}
.rm-code-pre code {
  font-family: inherit;
  font-size: inherit;
  color: inherit;
  background: none;
  padding: 0;
  border-radius: 0;
  white-space: pre;
}

/* ── PRODUCTION PITFALLS ──────────────────────────────────── */
.rm-pitfalls { display: flex; flex-direction: column; gap: 14px; }
.rm-pitfall {
  border: 1px solid var(--linen3);
  border-radius: 8px;
  overflow: hidden;
}
.rm-pitfall-head {
  display: flex;
