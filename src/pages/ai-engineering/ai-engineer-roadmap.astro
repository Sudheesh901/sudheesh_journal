[data-layer="production"] .rm-code-lang { color: var(--amber); }
[data-layer="ship"]       .rm-code-lang { color: var(--muted2); }
.rm-code-dots { display: flex; gap: 5px; align-items: center; }
.rm-dot { width: 10px; height: 10px; border-radius: 50%; }
.rm-dot--r { background: #FF5F57; }
.rm-dot--y { background: #FEBC2E; }
.rm-dot--g { background: #28C840; }
.rm-code-pre {
  margin: 0;
