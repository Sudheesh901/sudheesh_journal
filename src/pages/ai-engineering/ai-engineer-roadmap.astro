  color: var(--ink);
  letter-spacing: -0.045em;
}
.rm-ht-serif {
  font-family: var(--display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(3rem, 5.5vw, 5.6rem);
  color: var(--terra);
  letter-spacing: -0.03em;
}

.rm-hero-desc {
  font-size: clamp(0.95rem, 1.2vw, 1.08rem);
  color: var(--muted);
