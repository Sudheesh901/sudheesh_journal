    new_tokens = out.shape[1] - input_ids.shape[1]
    return {
        "text":    tokenizer.decode(out[0], skip_special_tokens=True),
        "tokens":  new_tokens,
        "tok_per_sec": round(new_tokens / elapsed, 1),
        "elapsed": round(elapsed, 3),
