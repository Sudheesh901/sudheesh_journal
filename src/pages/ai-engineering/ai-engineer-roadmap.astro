            model="gpt-4o-mini",
            messages=[{
                "role": "user",
                "content": (
                    f"Classify: {text[:500]}\\n"
                    "Categories: billing|technical|account|other\\n"
                    "Return only the category name."
                )
            }],
            max_tokens=10,
            temperature=0,
        )
        return resp.choices[0].message.content.strip().lower()
    except Exception:
        return legacy_rule_classify(text)  # graceful fallback`,
