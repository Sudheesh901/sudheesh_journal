.rm-qa-q:hover { background: var(--linen3); }
.rm-qa-q svg { flex-shrink: 0; color: var(--muted2); transition: transform 0.22s ease; }
.rm-qa-item--open .rm-qa-q svg { transform: rotate(180deg); }
.rm-qa-a {
