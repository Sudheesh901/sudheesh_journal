/* ── RESPONSIVE ─────────────────────────────────────────── */
@media (max-width: 1100px) {
  .rm-hero-inner,
  .rm-body {
    padding-left: 40px;
    padding-right: 40px;
  }
}

@media (max-width: 860px) {
  .rm-hero-inner {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 48px 32px 44px;
  }
  .rm-hero-index {
    border-left: none;
    border-top: 1px solid var(--linen3);
    padding-left: 0;
    padding-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px 32px;
  }
  .rm-body { padding-left: 32px; padding-right: 32px; }
}

@media (max-width: 560px) {
  .rm-ht-sans, .rm-ht-serif { font-size: clamp(2.4rem, 10vw, 3.2rem); }
  .rm-stage { gap: 20px; }
  .rm-stage-gutter { flex: 0 0 40px; width: 40px; }
  .rm-track::before { left: 19px; }
  /* Only collapse non-expandable spec rows to single column */
  .rm-spec-row:not(.rm-spec-row--has-detail) { grid-template-columns: 1fr; }
  .rm-spec-row:not(.rm-spec-row--has-detail) .rm-spec-term {
    border-right: none;
    border-bottom: 1px solid var(--linen3);
  }
  /* Expandable rows: collapse term to full width on its own row */
  .rm-spec-row--has-detail { grid-template-columns: minmax(0,1fr) 36px; }
  .rm-spec-row--has-detail .rm-spec-term {
    grid-column: 1 / -1;
    border-right: none;
    border-bottom: 1px solid var(--linen3);
  }
  .rm-det-pane { padding: 16px; }
  .rm-code-pre { padding: 14px 16px; font-size: 0.72rem; }
  .rm-hero-index { grid-template-columns: 1fr; }
  .rm-hero-inner, .rm-body { padding-left: 20px; padding-right: 20px; }
}
</style>

<script is:inline>
/* ── Expand / collapse detail panel ── */
function rmToggle(row) {
  var item = row.closest('.rm-spec-item');
  var isOpen = item.classList.contains('rm-spec-item--open');
  // Accordion: close all others in the same spec table
  var spec = row.closest('.rm-spec');
  spec.querySelectorAll('.rm-spec-item--open').forEach(function (el) {
    el.classList.remove('rm-spec-item--open');
  });
  if (!isOpen) {
    item.classList.add('rm-spec-item--open');
  }
}

/* ── Switch tabs inside a detail panel ── */
function rmTab(btn, pane) {
  var det = btn.closest('.rm-det');
  det.querySelectorAll('.rm-det-tab').forEach(function (t) {
    t.classList.remove('rm-det-tab--active');
  });
  det.querySelectorAll('.rm-det-pane').forEach(function (p) {
    p.classList.remove('rm-det-pane--active');
  });
  btn.classList.add('rm-det-tab--active');
  var target = det.querySelector('[data-pane="' + pane + '"]');
  if (target) target.classList.add('rm-det-pane--active');
}

/* ── Toggle Q&A accordion ── */
function rmQA(btn) {
  var item = btn.closest('.rm-qa-item');
  var isOpen = item.classList.contains('rm-qa-item--open');
  var list = btn.closest('.rm-qa-list');
  list.querySelectorAll('.rm-qa-item--open').forEach(function (el) {
    el.classList.remove('rm-qa-item--open');
  });
  if (!isOpen) { item.classList.add('rm-qa-item--open'); }
}

/* ── Stage entrance animation ── */
(function () {
  var stages = document.querySelectorAll('.rm-stage');
  if (!stages.length) return;
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('rm-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.05 });
  stages.forEach(function (s) { io.observe(s); });
})();
</script>
