---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="page-hero">
  <div class="page-hero-inner">
    <div class="eyebrow">{eyebrow}</div>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
</div>
