---
interface Props {
  href: string;
  title: string;
  description: string;
  tags?: string[];
  meta?: string;
}

const { href, title, description, tags = [], meta = '' } = Astro.props;
---

<a class="topic-card kb-card-link" href={href}>
  {meta && <div class="eyebrow" style="margin-bottom:8px;">{meta}</div>}
  <div class="topic-name">{title}</div>
  <p class="topic-desc">{description}</p>
  <div class="topic-tags">
    {tags.slice(0, 5).map((tag) => <span class="tag">{tag}</span>)}
  </div>
</a>
